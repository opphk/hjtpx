    {
      "name": "6. 管理端 - 统计API",
      "item": [
        {
          "name": "6.1 获取仪表盘统计",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/stats/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "stats", "dashboard"]
            },
            "description": "获取仪表盘统计数据"
          },
          "response": []
        },
        {
          "name": "6.2 获取验证趋势",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/stats/trends?start_date=2024-01-01&end_date=2024-01-31&interval=day",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "stats", "trends"],
              "query": [
                {
                  "key": "start_date",
                  "value": "2024-01-01"
