    {
      "name": "2. 用户端 - 认证API",
      "item": [
        {
          "name": "2.1 用户注册",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"username\": \"testuser\",\n  \"captcha_token\": \"captcha_token_xyz123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "用户注册新账号"
          },
          "response": [
            {
              "name": "注册成功",
              "originalRequest": {},
              "status": "OK",
              "code": 200,
              "body": "{\n  \"code\": 0,\n  \"message\": \"注册成功\",\n  \"data\": {\n    \"user_id\": \"usr_123456\",\n    \"username\": \"testuser\",\n    \"email\": \"user@example.com\",\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"refresh_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"expires_in\": 86400\n  }\n}"
            }
          ]
        },
        {
          "name": "2.2 用户登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.code === 0 && jsonData.data.access_token) {",
                  "    pm.collectionVariables.set(\"authToken\", jsonData.data.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"captcha_token\": \"captcha_token_xyz123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "用户登录获取Token"
          },
          "response": [
            {
              "name": "登录成功",
              "originalRequest": {},
              "status": "OK",
              "code": 200,
              "body": "{\n  \"code\": 0,\n  \"message\": \"登录成功\",\n  \"data\": {\n    \"user_id\": \"usr_123456\",\n    \"username\": \"testuser\",\n    \"email\": \"user@example.com\",\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"refresh_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"expires_in\": 86400\n  }\n}"
            }
          ]
        },
        {
          "name": "2.3 刷新Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "刷新访问Token"
          },
          "response": []
        },
        {
          "name": "2.4 用户登出",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "用户登出"
          },
          "response": []
        },
        {
          "name": "2.5 请求重置密码",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/reset-password/request",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "reset-password", "request"]
            },
            "description": "请求重置密码邮件"
          },
          "response": []
        },
        {
          "name": "2.6 确认重置密码",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"reset_token_123\",\n  \"new_password\": \"NewSecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/reset-password/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "reset-password", "confirm"]
            },
            "description": "确认重置密码"
          },
          "response": []
        }
      ]
    },
