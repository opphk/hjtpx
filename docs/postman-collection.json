{
  "info": {
    "_postman_id": "hjtpx-behavior-captcha-api",
    "name": "行为验证系统 API",
    "description": "行为验证系统完整API集合，包含用户端、管理端、监控等所有接口",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. 环境配置",
      "description": "API基础配置和环境变量",
      "item": [
        {
          "name": "设置环境变量",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set(\"baseUrl\", \"http://localhost:8080\");",
                  "pm.collectionVariables.set(\"apiKey\", \"your-api-key\");",
                  "pm.collectionVariables.set(\"authToken\", \"\");"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "1. 用户端 - 验证码API",
      "item": [
        {
          "name": "1.1 获取滑块验证码",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"width\": 320,\n  \"height\": 160,\n  \"tolerance\": 8,\n  \"difficulty\": \"medium\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/captcha/slider",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "captcha", "slider"]
            },
            "description": "获取滑块验证码图片和验证信息"
          },
          "response": [
            {
              "name": "成功响应",
              "originalRequest": {},
              "status": "OK",
              "code": 200,
              "body": "{\n  \"code\": 0,\n  \"message\": \"success\",\n  \"data\": {\n    \"session_id\": \"sess_abc123xyz\",\n    \"background_image\": \"data:image/png;base64,iVBORw0KGgo...\",\n    \"puzzle_image\": \"data:image/png;base64,iVBORw0KGgo...\",\n    \"puzzle_x\": 150,\n    \"puzzle_y\": 80\n  }\n}"
            }
          ]
        },
        {
          "name": "1.2 验证滑块验证码",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"sess_abc123xyz\",\n  \"x\": 152,\n  \"y\": 80,\n  \"trajectory\": [\n    {\"x\": 0, \"y\": 0, \"t\": 0},\n    {\"x\": 50, \"y\": 2, \"t\": 100},\n    {\"x\": 100, \"y\": -1, \"t\": 200},\n    {\"x\": 152, \"y\": 0, \"t\": 350}\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/captcha/slider/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "captcha", "slider", "verify"]
            },
            "description": "验证用户滑动结果"
          },
          "response": [
            {
              "name": "验证成功",
              "originalRequest": {},
              "status": "OK",
              "code": 200,
              "body": "{\n  \"code\": 0,\n  \"message\": \"success\",\n  \"data\": {\n    \"valid\": true,\n    \"token\": \"captcha_token_xyz123\",\n    \"risk_score\": 0.12,\n    \"duration\": 350\n  }\n}"
            },
            {
              "name": "验证失败",
              "originalRequest": {},
              "status": "OK",
              "code": 200,
              "body": "{\n  \"code\": 10001,\n  \"message\": \"验证失败，请重试\",\n  \"data\": {\n    \"valid\": false,\n    \"risk_score\": 0.89,\n    \"reason\": \"trajectory_abnormal\"\n  }\n}"
            }
          ]
        },
        {
          "name": "1.3 获取图形验证码",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/captcha/image?width=160&height=60&length=4",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "captcha", "image"],
              "query": [
                {
                  "key": "width",
                  "value": "160"
                },
                {
                  "key": "height",
                  "value": "60"
                },
                {
                  "key": "length",
                  "value": "4"
                }
              ]
            },
            "description": "获取图形验证码"
          },
          "response": []
        },
        {
          "name": "1.4 验证图形验证码",
          "request": {
