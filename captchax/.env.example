TZ=Asia/Shanghai

VERSION=1.0.0

POSTGRES_USER=captcha_admin
POSTGRES_PASSWORD=captcha_pass_2026
POSTGRES_DB=captcha_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

DB_HOST=${POSTGRES_HOST}
DB_PORT=${POSTGRES_PORT}
DB_USER=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}
DB_NAME=${POSTGRES_DB}

CAPTCHAX_PORT=8080
CAPTCHAX_HOST=0.0.0.0
CAPTCHAX_MODE=release

LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

CAPTCHA_EXPIRE_MINUTES=5
CAPTCHA_MAX_ATTEMPTS=3
CAPTCHA_WIDTH=200
CAPTCHA_HEIGHT=80
CAPTCHA_LENGTH=4
CAPTCHA_SLIDER_SIZE=50
CAPTCHA_TOLERANCE=5

ADMIN_JWT_SECRET=change-this-secret-in-production
ADMIN_TOKEN_TTL=86400
ADMIN_COOKIE_NAME=admin_token

BACKUP_DIR=/var/backups/captchax
RETENTION_DAYS=7
