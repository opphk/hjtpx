<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CaptchaX Android SDK Demo"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="滑块验证"
        android:layout_marginBottom="8dp"
        android:onClick="showSliderCaptcha" />

    <com.google.android.material.button.MaterialButton
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="点选验证"
        android:layout_marginBottom="8dp"
        android:onClick="showClickCaptcha" />

    <com.google.android.material.button.MaterialButton
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="拼图验证"
        android:layout_marginBottom="8dp"
        android:onClick="showPuzzleCaptcha" />

    <com.google.android.material.button.MaterialButton
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="旋转验证"
        android:layout_marginBottom="8dp"
        android:onClick="showRotateCaptcha" />

    <com.google.android.material.button.MaterialButton
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="文字验证"
        android:layout_marginBottom="8dp"
        android:onClick="showTextCaptcha" />

    <com.google.android.material.button.MaterialButton
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="图标验证"
        android:layout_marginBottom="8dp"
        android:onClick="showIconCaptcha" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#e0e0e0"
        android:layout_marginVertical="16dp" />

    <com.google.android.material.button.MaterialButton
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="预加载验证码"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:onClick="preloadCaptcha" />

</LinearLayout>
