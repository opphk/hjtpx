groups:
  - name: hjtpx-app
    interval: 30s
    rules:
      - alert: HJTXPAppDown
        expr: up{job="hjtpx-app"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "HJTPX application is down"
          description: "HJTPX application instance {{ $labels.instance }} has been down for more than 1 minute"

      - alert: HJTXPHighErrorRate
        expr: rate(hjtpx_http_requests_total{job="hjtpx-app",status_code=~"5.."}[5m]) / rate(hjtpx_http_requests_total{job="hjtpx-app"}[5m]) > 0.05
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high error rate"
          description: "HJTPX application error rate is above 5% for more than 5 minutes. Current rate: {{ $value | printf \"%.2f\" }}%"

      - alert: HJTXPTooManyErrors
        expr: rate(hjtpx_http_requests_total{job="hjtpx-app",status_code=~"5.."}[5m]) / rate(hjtpx_http_requests_total{job="hjtpx-app"}[5m]) > 0.15
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "HJTPX critical error rate"
          description: "HJTPX application error rate is above 15% for more than 3 minutes. Current rate: {{ $value | printf \"%.2f\" }}%"

      - alert: HJTXPHighLatency
        expr: histogram_quantile(0.95, rate(hjtpx_http_request_duration_seconds_bucket{job="hjtpx-app"}[5m])) > 1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high latency"
          description: "HJTPX 95th percentile latency is above 1 second for more than 5 minutes. Current p95: {{ $value | printf \"%.2f\" }}s"

      - alert: HJTXPTooHighLatency
        expr: histogram_quantile(0.95, rate(hjtpx_http_request_duration_seconds_bucket{job="hjtpx-app"}[5m])) > 3
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "HJTPX critical latency"
          description: "HJTPX 95th percentile latency is above 3 seconds for more than 3 minutes. Current p95: {{ $value | printf \"%.2f\" }}s"

      - alert: HJTXPHighMemoryUsage
        expr: process_resident_memory_bytes{job="hjtpx-app"} / process_memory_limit_bytes > 0.85
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high memory usage"
          description: "HJTPX memory usage is above 85% for more than 10 minutes. Current usage: {{ $value | printf \"%.2f\" }}%"

      - alert: HJTXPTooHighMemoryUsage
        expr: process_resident_memory_bytes{job="hjtpx-app"} / process_memory_limit_bytes > 0.95
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "HJTPX critical memory usage"
          description: "HJTPX memory usage is above 95% for more than 5 minutes. Current usage: {{ $value | printf \"%.2f\" }}%"

      - alert: HJTXPHighCPUUsage
        expr: rate(process_cpu_seconds_total{job="hjtpx-app"}[5m]) * 100 > 80
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high CPU usage"
          description: "HJTPX CPU usage is above 80% for more than 10 minutes. Current usage: {{ $value | printf \"%.2f\" }}%"

      - alert: HJTXPTooHighCPUUsage
        expr: rate(process_cpu_seconds_total{job="hjtpx-app"}[5m]) * 100 > 95
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "HJTPX critical CPU usage"
          description: "HJTPX CPU usage is above 95% for more than 5 minutes. Current usage: {{ $value | printf \"%.2f\" }}%"

      - alert: HJTXPHighRequestRate
        expr: rate(hjtpx_http_requests_total{job="hjtpx-app"}[5m]) > 1000
        for: 5m
        labels:
          severity: info
        annotations:
          summary: "HJTPX high request rate"
          description: "HJTPX request rate is above 1000 req/s for more than 5 minutes"

      - alert: HJTXPBlockedRequests
        expr: rate(hjtpx_captcha_blocked_total[5m]) > 10
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high blocked request rate"
          description: "HJTPX blocked request rate is above 10/s for more than 5 minutes"

      - alert: HJTXPTooManyBlockedRequests
        expr: rate(hjtpx_captcha_blocked_total[5m]) > 100
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "HJTPX critical blocked request rate"
          description: "HJTPX blocked request rate is above 100/s for more than 3 minutes"

      - alert: HJTXPHealthCheckFailure
        expr: up{job="hjtpx-health"} == 0
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX health check failure"
          description: "HJTPX health check endpoint is not responding for more than 2 minutes"

  - name: captcha-monitoring
    interval: 30s
    rules:
      - alert: CaptchaLowSuccessRate
        expr: sum(rate(hjtpx_captcha_verified_total{result="success"}[5m])) / sum(rate(hjtpx_captcha_verified_total[5m])) < 0.7
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Captcha success rate is low"
          description: "Captcha success rate is below 70% for more than 5 minutes. Current rate: {{ $value | printf \"%.2f\" }}%"

      - alert: CaptchaCriticalSuccessRate
        expr: sum(rate(hjtpx_captcha_verified_total{result="success"}[5m])) / sum(rate(hjtpx_captcha_verified_total[5m])) < 0.5
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Captcha success rate is critically low"
          description: "Captcha success rate is below 50% for more than 3 minutes. Current rate: {{ $value | printf \"%.2f\" }}%"

      - alert: CaptchaHighVerifyLatency
        expr: histogram_quantile(0.95, rate(hjtpx_captcha_verify_duration_seconds_bucket[5m])) > 0.5
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Captcha verification latency is high"
          description: "Captcha verification P95 latency is above 500ms for more than 5 minutes. Current p95: {{ $value | printf \"%.2f\" }}s"

      - alert: CaptchaCriticalVerifyLatency
        expr: histogram_quantile(0.95, rate(hjtpx_captcha_verify_duration_seconds_bucket[5m])) > 1
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Captcha verification latency is critically high"
          description: "Captcha verification P95 latency is above 1 second for more than 3 minutes. Current p95: {{ $value | printf \"%.2f\" }}s"

      - alert: CaptchaHighBlockRate
        expr: rate(hjtpx_captcha_blocked_total[5m]) > 50
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High captcha block rate"
          description: "Captcha block rate is above 50/s for more than 5 minutes. This may indicate an attack or misconfiguration."

      - alert: CaptchaNoGeneration
        expr: rate(hjtpx_captcha_generated_total[5m]) == 0
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "No captcha generation detected"
          description: "No captchas have been generated in the last 10 minutes. This may indicate a service issue."

  - name: security-monitoring
    interval: 30s
    rules:
      - alert: SecurityHighBlockRate
        expr: rate(hjtpx_security_blocked_total[5m]) > 20
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High security block rate"
          description: "Security block rate is above 20/s for more than 5 minutes. This may indicate an attack."

      - alert: SecurityCriticalBlockRate
        expr: rate(hjtpx_security_blocked_total[5m]) > 100
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Critical security block rate"
          description: "Security block rate is above 100/s for more than 3 minutes. Immediate investigation required."

      - alert: BotDetectionHighRate
        expr: rate(hjtpx_bot_detection_total{action="blocked"}[5m]) > 10
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High bot detection rate"
          description: "Bot detection blocking rate is above 10/s for more than 5 minutes."

      - alert: ProxyDetectionHighRate
        expr: rate(hjtpx_proxy_detection_total[5m]) > 20
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High proxy/VPN detection rate"
          description: "Proxy or VPN detection rate is above 20/s for more than 5 minutes. This may indicate suspicious activity."

      - alert: HighRiskScoreRequests
        expr: histogram_quantile(0.95, sum(rate(hjtpx_security_risk_score_bucket[5m])) by (le)) > 80
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High risk score requests detected"
          description: "Risk scores are frequently above 80 for the last 5 minutes. Review security logs."

      - alert: RateLimitHighHits
        expr: rate(hjtpx_rate_limit_hits_total[5m]) > 50
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High rate limit hits"
          description: "Rate limit hits are above 50/s for more than 5 minutes. This may indicate abuse or DDoS."

      - alert: BlacklistHighHits
        expr: rate(hjtpx_blacklist_hits_total[5m]) > 10
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High blacklist hits"
          description: "Blacklist hits are above 10/s for more than 5 minutes. Review blacklist entries."

  - name: auth-monitoring
    interval: 30s
    rules:
      - alert: AuthLowSuccessRate
        expr: sum(rate(hjtpx_auth_attempts_total{result="success"}[5m])) / sum(rate(hjtpx_auth_attempts_total[5m])) < 0.7
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Authentication success rate is low"
          description: "Authentication success rate is below 70% for more than 5 minutes. Current rate: {{ $value | printf \"%.2f\" }}%"

      - alert: AuthCriticalSuccessRate
        expr: sum(rate(hjtpx_auth_attempts_total{result="success"}[5m])) / sum(rate(hjtpx_auth_attempts_total[5m])) < 0.5
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Authentication success rate is critically low"
          description: "Authentication success rate is below 50% for more than 3 minutes. Current rate: {{ $value | printf \"%.2f\" }}%"

      - alert: MFAHighFailureRate
        expr: sum(rate(hjtpx_mfa_attempts_total{result="failure"}[5m])) / sum(rate(hjtpx_mfa_attempts_total[5m])) > 0.3
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "MFA failure rate is high"
          description: "MFA failure rate is above 30% for more than 5 minutes. Current rate: {{ $value | printf \"%.2f\" }}%"

      - alert: AuthBruteForceSuspected
        expr: sum(rate(hjtpx_auth_attempts_total{result="failure"}[5m])) > 100
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Possible brute force attack detected"
          description: "Authentication failures are above 100/s for more than 5 minutes. This may indicate a brute force attack."

  - name: websocket-monitoring
    interval: 30s
    rules:
      - alert: WebSocketHighConnections
        expr: hjtpx_websocket_connections_active > 1000
        for: 5m
        labels:
          severity: info
        annotations:
          summary: "High WebSocket connections"
          description: "WebSocket connections are above 1000 for more than 5 minutes. Current count: {{ $value }}"

      - alert: WebSocketCriticalConnections
        expr: hjtpx_websocket_connections_active > 5000
        for: 3m
        labels:
          severity: warning
        annotations:
          summary: "Critical WebSocket connections"
          description: "WebSocket connections are above 5000 for more than 3 minutes. Current count: {{ $value }}"

      - alert: WebSocketHighMessageRate
        expr: rate(hjtpx_websocket_messages_total[5m]) > 10000
        for: 5m
        labels:
          severity: info
        annotations:
          summary: "High WebSocket message rate"
          description: "WebSocket message rate is above 10000/s for more than 5 minutes."

  - name: database
    interval: 30s
    rules:
      - alert: PostgreSQLDown
        expr: up{job="postgres-exporter"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "PostgreSQL is down"
          description: "PostgreSQL instance is not responding"

      - alert: PostgreSQLHighConnections
        expr: pg_stat_database_numbackends / pg_settings_max_connections > 0.8
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "PostgreSQL high connection usage"
          description: "PostgreSQL connection usage is above 80%. Current usage: {{ $value | printf \"%.2f\" }}%"

      - alert: PostgreSQLTooManyConnections
        expr: pg_stat_database_numbackends / pg_settings_max_connections > 0.95
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "PostgreSQL critical connection usage"
          description: "PostgreSQL connection usage is above 95%. Current usage: {{ $value | printf \"%.2f\" }}%"

      - alert: PostgreSQLSlowQueries
        expr: rate(hjtpx_db_slow_queries_total[5m]) > 10
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "PostgreSQL slow queries"
          description: "PostgreSQL slow query rate is above 10/s for more than 5 minutes."

      - alert: PostgreSQLLongRunningTransactions
        expr: rate(pg_stat_database_blocked{job="postgres-exporter"}[5m]) > 10
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "PostgreSQL long running transactions"
          description: "PostgreSQL has high number of blocked transactions"

      - alert: PostgreSQLReplicationLag
        expr: pg_replication_lag_seconds > 30
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "PostgreSQL replication lag"
          description: "PostgreSQL replication lag is above 30 seconds. Current lag: {{ $value | printf \"%.2f\" }}s"

  - name: redis
    interval: 30s
    rules:
      - alert: RedisDown
        expr: up{job="redis-exporter"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Redis is down"
          description: "Redis instance is not responding"

      - alert: RedisHighMemoryUsage
        expr: redis_memory_used_bytes / redis_memory_max_bytes > 0.85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Redis high memory usage"
          description: "Redis memory usage is above 85%. Current usage: {{ $value | printf \"%.2f\" }}%"

      - alert: RedisTooHighMemoryUsage
        expr: redis_memory_used_bytes / redis_memory_max_bytes > 0.95
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Redis critical memory usage"
          description: "Redis memory usage is above 95%. Current usage: {{ $value | printf \"%.2f\" }}%"

      - alert: RedisHighEvictionRate
        expr: rate(redis_evicted_keys_total{job="redis-exporter"}[5m]) > 100
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Redis high eviction rate"
          description: "Redis is evicting keys at a high rate (>100/s)"

      - alert: RedisTooManyEvictions
        expr: rate(redis_evicted_keys_total{job="redis-exporter"}[5m]) > 1000
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Redis critical eviction rate"
          description: "Redis is evicting keys at a critical rate (>1000/s)"

      - alert: RedisHighConnectionUsage
        expr: redis_connected_clients / redis_config_maxclients > 0.8
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Redis high connection usage"
          description: "Redis connection usage is above 80%"

      - alert: RedisKeyspaceMissRate
        expr: rate(redis_keyspace_hits_total{job="redis-exporter"}[5m]) / (rate(redis_keyspace_hits_total{job="redis-exporter"}[5m]) + rate(redis_keyspace_misses_total{job="redis-exporter"}[5m])) < 0.5
        for: 10m
        labels:
          severity: info
        annotations:
          summary: "Redis high cache miss rate"
          description: "Redis cache hit ratio is below 50%"

  - name: nginx
    interval: 30s
    rules:
      - alert: NginxDown
        expr: up{job="nginx"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Nginx is down"
          description: "Nginx instance is not responding"

      - alert: NginxHighErrorRate
        expr: rate(nginx_http_requests_total{status=~"5.."}[5m]) / rate(nginx_http_requests_total[5m]) > 0.05
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Nginx high error rate"
          description: "Nginx error rate is above 5%"

      - alert: NginxTooHighErrorRate
        expr: rate(nginx_http_requests_total{status=~"5.."}[5m]) / rate(nginx_http_requests_total[5m]) > 0.15
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Nginx critical error rate"
          description: "Nginx error rate is above 15%"

      - alert: NginxHighLatency
        expr: histogram_quantile(0.95, rate(nginx_http_request_duration_seconds_bucket[5m])) > 2
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Nginx high latency"
          description: "Nginx 95th percentile latency is above 2 seconds"

      - alert: NginxTooHighLatency
        expr: histogram_quantile(0.95, rate(nginx_http_request_duration_seconds_bucket[5m])) > 5
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Nginx critical latency"
          description: "Nginx 95th percentile latency is above 5 seconds"

      - alert: NginxHighConnectionUsage
        expr: nginx_connections_active > 10000
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Nginx high connection usage"
          description: "Nginx has more than 10000 active connections"

  - name: node
    interval: 30s
    rules:
      - alert: NodeHighCPU
        expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 80
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Node high CPU usage"
          description: "Node CPU usage is above 80%"

      - alert: NodeCriticalCPU
        expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 95
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Node critical CPU usage"
          description: "Node CPU usage is above 95%"

      - alert: NodeHighMemory
        expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100 > 85
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Node high memory usage"
          description: "Node memory usage is above 85%"

      - alert: NodeCriticalMemory
        expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100 > 95
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Node critical memory usage"
          description: "Node memory usage is above 95%"

      - alert: NodeHighDiskUsage
        expr: (node_filesystem_avail_bytes{fstype!~"tmpfs|fuse.lxcfs"} / node_filesystem_size_bytes{fstype!~"tmpfs|fuse.lxcfs"}) * 100 < 15
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Node high disk usage"
          description: "Node disk usage is above 85%"

      - alert: NodeCriticalDiskUsage
        expr: (node_filesystem_avail_bytes{fstype!~"tmpfs|fuse.lxcfs"} / node_filesystem_size_bytes{fstype!~"tmpfs|fuse.lxcfs"}) * 100 < 5
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Node critical disk usage"
          description: "Node disk usage is above 95%"

      - alert: NodeDiskIOHigh
        expr: rate(node_disk_io_time_seconds_total[5m]) > 0.8
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Node high disk I/O"
          description: "Node disk I/O utilization is above 80%"

      - alert: NodeNetworkIssues
        expr: rate(node_network_receive_errors_total[5m]) + rate(node_network_transmit_errors_total[5m]) > 10
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Node network errors"
          description: "Node has high network error rate"

  - name: loki
    interval: 60s
    rules:
      - alert: LokiDown
        expr: up{job="loki"} == 0
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "Loki is down"
          description: "Loki instance is not responding"

      - alert: LokiHighIngesterErrors
        expr: rate(loki_ingester_client_failed_reconnects_total[5m]) > 10
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Loki high ingester errors"
          description: "Loki ingester is experiencing high reconnection errors"

  - name: captcha
    interval: 30s
    rules:
      - alert: HJTXPHighCaptchaBlockRate
        expr: rate(hjtpx_captcha_blocked_total[5m]) / rate(hjtpx_captcha_total[5m]) > 0.2
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high captcha block rate"
          description: "Captcha block rate is above 20% for more than 5 minutes. Current rate: {{ $value | printf \"%.2f\" }}%"

      - alert: HJTXPTooHighCaptchaBlockRate
        expr: rate(hjtpx_captcha_blocked_total[5m]) / rate(hjtpx_captcha_total[5m]) > 0.5
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "HJTPX critical captcha block rate"
          description: "Captcha block rate is above 50% for more than 3 minutes. Current rate: {{ $value | printf \"%.2f\" }}%"

      - alert: HJTXPHighCaptchaVerifyLatency
        expr: histogram_quantile(0.95, rate(hjtpx_captcha_verify_duration_seconds_bucket[5m])) > 1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high captcha verify latency"
          description: "Captcha verify P95 latency is above 1 second for more than 5 minutes. Current P95: {{ $value | printf \"%.2f\" }}s"

      - alert: HJTXPTooHighCaptchaVerifyLatency
        expr: histogram_quantile(0.95, rate(hjtpx_captcha_verify_duration_seconds_bucket[5m])) > 3
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "HJTPX critical captcha verify latency"
          description: "Captcha verify P95 latency is above 3 seconds for more than 3 minutes. Current P95: {{ $value | printf \"%.2f\" }}s"

      - alert: HJTXPHighCaptchaErrorRate
        expr: rate(hjtpx_captcha_total{status="error"}[5m]) / rate(hjtpx_captcha_total[5m]) > 0.1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high captcha error rate"
          description: "Captcha error rate is above 10% for more than 5 minutes. Current rate: {{ $value | printf \"%.2f\" }}%"

  - name: websocket
    interval: 30s
    rules:
      - alert: HJTXPHighWebSocketConnections
        expr: hjtpx_websocket_connections_active > 1000
        for: 5m
        labels:
          severity: info
        annotations:
          summary: "HJTPX high WebSocket connections"
          description: "WebSocket active connections are above 1000 for more than 5 minutes"

      - alert: HJTXPTooManyWebSocketConnections
        expr: hjtpx_websocket_connections_active > 5000
        for: 3m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX too many WebSocket connections"
          description: "WebSocket active connections are above 5000 for more than 3 minutes"

      - alert: HJTXPWebSocketConnectionDrop
        expr: rate(hjtpx_websocket_messages_total{direction="disconnect"}[5m]) > 100
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high WebSocket connection drop rate"
          description: "WebSocket connection drop rate is above 100/s for more than 5 minutes"

      - alert: HJTXPHighWebSocketMessageLatency
        expr: histogram_quantile(0.95, rate(hjtpx_websocket_message_duration_seconds_bucket[5m])) > 0.5
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high WebSocket message latency"
          description: "WebSocket message P95 latency is above 500ms for more than 5 minutes. Current P95: {{ $value | printf \"%.2f\" }}s"

  - name: security
    interval: 30s
    rules:
      - alert: HJTXPHighSecurityEvents
        expr: rate(hjtpx_security_events_total[5m]) > 50
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high security events rate"
          description: "Security events rate is above 50/s for more than 5 minutes"

      - alert: HJTXPTooManySecurityEvents
        expr: rate(hjtpx_security_events_total[5m]) > 200
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "HJTPX critical security events rate"
          description: "Security events rate is above 200/s for more than 3 minutes"

      - alert: HJTXPHighBotDetectionRate
        expr: rate(hjtpx_bot_detection_total{action="block"}[5m]) > 10
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high bot detection rate"
          description: "Bot detection block rate is above 10/s for more than 5 minutes"

      - alert: HJTXPTooManyBotDetections
        expr: rate(hjtpx_bot_detection_total{action="block"}[5m]) > 50
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "HJTPX critical bot detection rate"
          description: "Bot detection block rate is above 50/s for more than 3 minutes"

      - alert: HJTXPHighRateLimitHits
        expr: rate(hjtpx_rate_limit_hits_total[5m]) > 100
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "HJTPX high rate limit hits"
          description: "Rate limit hits are above 100/s for more than 5 minutes"
