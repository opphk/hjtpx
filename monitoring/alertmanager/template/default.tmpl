{{ define "email.default.html" }}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; margin: 0; padding: 20px; background-color: #f5f5f5; }
        .container { background-color: white; border-radius: 8px; padding: 20px; max-width: 800px; margin: 0 auto; }
        .header { border-bottom: 2px solid #e74c3c; padding-bottom: 10px; margin-bottom: 20px; }
        .header.critical { border-bottom-color: #e74c3c; }
        .header.warning { border-bottom-color: #f39c12; }
        .header.info { border-bottom-color: #3498db; }
        h1 { margin: 0; color: #2c3e50; font-size: 24px; }
        .status { display: inline-block; padding: 5px 10px; border-radius: 4px; color: white; font-weight: bold; margin-top: 10px; }
        .status.firing { background-color: #e74c3c; }
        .status.resolved { background-color: #27ae60; }
        .alert { border: 1px solid #ddd; border-radius: 4px; padding: 15px; margin-bottom: 15px; background-color: #fafafa; }
        .alert-label { font-weight: bold; color: #34495e; margin-bottom: 5px; }
        .alert-value { color: #7f8c8d; margin-bottom: 10px; }
        .description { background-color: #ecf0f1; padding: 10px; border-radius: 4px; margin-top: 10px; }
        .footer { margin-top: 20px; padding-top: 10px; border-top: 1px solid #ddd; color: #7f8c8d; font-size: 12px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header {{ if eq .Status "firing" }}critical{{ else if eq .GroupLabels.severity "warning" }}warning{{ else }}info{{ end }}">
            <h1>{{ .GroupLabels.alertname }}</h1>
            <span class="status {{ .Status }}">{{ .Status | toUpper }}</span>
        </div>
        
        {{ range .Alerts }}
        <div class="alert">
            <div class="alert-label">Summary</div>
            <div class="alert-value">{{ .Annotations.summary }}</div>
            
            <div class="alert-label">Description</div>
            <div class="description">{{ .Annotations.description }}</div>
            
            <div style="margin-top: 15px;">
                {{ if .Labels.instance }}<strong>Instance:</strong> {{ .Labels.instance }}<br>{{ end }}
                {{ if .Labels.severity }}<strong>Severity:</strong> {{ .Labels.severity }}<br>{{ end }}
                {{ if .Labels.cluster }}<strong>Cluster:</strong> {{ .Labels.cluster }}<br>{{ end }}
                {{ if .Labels.job }}<strong>Job:</strong> {{ .Labels.job }}<br>{{ end }}
            </div>
            
            <div style="margin-top: 10px; font-size: 12px; color: #7f8c8d;">
                <strong>Started:</strong> {{ .StartsAt }}
                {{ if .EndsAt }}<br><strong>Ended:</strong> {{ .EndsAt }}{{ end }}
            </div>
        </div>
        {{ end }}
        
        <div class="footer">
            <p>This alert was generated by AlertManager for HJTPX monitoring system.</p>
            <p>Alert Group: {{ .GroupLabels.alertname }} | Status: {{ .Status }}</p>
        </div>
    </div>
</body>
</html>
{{ end }}

{{ define "slack.default.text" }}
{{ range .Alerts }}
*Alert:* {{ .Labels.alertname }}
*Severity:* {{ .Labels.severity }}
*Status:* {{ .Status | toUpper }}
{{ if .Annotations.summary }}*Summary:* {{ .Annotations.summary }}{{ end }}
{{ if .Annotations.description }}*Description:* {{ .Annotations.description }}{{ end }}
{{ if .Labels.instance }}*Instance:* {{ .Labels.instance }}{{ end }}
*Time:* {{ .StartsAt }}
---
{{ end }}
{{ end }}
