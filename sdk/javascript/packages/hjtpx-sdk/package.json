{
  "name": "hjtpx-sdk",
  "version": "1.0.0",
  "description": "hjtpx JavaScript/TypeScript SDK - 极验行为验证系统 SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "captcha",
    "verification",
    "security",
    "hjtpx",
    "slider-captcha",
    "click-captcha",
    "image-captcha"
  ],
  "author": "hjtpx Team <team@hjtpx.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hjtpx/hjtpx.git",
    "directory": "sdk/javascript"
  },
  "bugs": {
    "url": "https://github.com/hjtpx/hjtpx/issues"
  },
  "homepage": "https://github.com/hjtpx/hjtpx#readme",
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
