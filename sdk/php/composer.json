{
  "name": "hjtpx/captcha-sdk",
  "description": "HJTPX Captcha System PHP SDK - supports multiple captcha types including slider, click, gesture, voice, 3D and more",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "captcha",
    "verification",
    "security",
    "slider",
    "click",
    "gesture",
    "voice",
    "3d",
    "lianliankan"
  ],
  "authors": [
    {
      "name": "HJTPX Team",
      "email": "team@hjtpx.com"
    }
  ],
  "support": {
    "issues": "https://github.com/hjtpx/sdk/issues",
    "source": "https://github.com/hjtpx/sdk"
  },
  "require": {
    "php": ">=7.4",
    "guzzlehttp/guzzle": "^7.0",
    "psr/http-message": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "squizlabs/php_codesniffer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "HJTPX\\Captcha\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "HJTPX\\Captcha\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "cs-check": "phpcs src",
    "cs-fix": "phpcbf src"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  }
}
