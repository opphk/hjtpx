{
  "name": "hjtpx",
  "version": "1.0.0",
  "description": "HJTPX 主项目",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:report": "bash scripts/generate-coverage.sh",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "hjtpx",
    "project"
  ],
  "author": "HJTPX Developer",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "socket.io": "^4.8.3",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/react": "^16.3.2",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.0.0",
    "supertest": "^6.3.3"
  }
}
