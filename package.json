{
  "name": "hjtpx",
  "version": "1.0.0",
  "description": "HJTPX 主项目",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:report": "bash scripts/generate-coverage.sh",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:api": "jest --testPathPattern=tests/integration",
    "test:auth": "jest --testPathPattern=auth",
    "test:files": "jest --testPathPattern=files",
    "test:notifications": "jest --testPathPattern=notifications",
    "test:users": "jest --testPathPattern=users",
    "test:all": "node scripts/runTests.js all",
    "test:custom": "node scripts/runTests.js",
    "lint": "eslint src/",
    "format:check": "prettier --check src/",
    "format": "prettier --write src/",
    "audit": "npm audit",
    "audit:json": "npm audit --json",
    "audit:fix": "npm audit fix",
    "security:scan": "npm audit && npm run security:vulnerability-check",
    "security:vulnerability-check": "node -e \"const audit = require('./src/backend/services/securityAudit'); audit.runVulnerabilityScan();\"",
    "security:report": "npm audit --json > security-audit-report.json && echo 'Security audit report generated: security-audit-report.json'",
    "backup:full": "node scripts/backup.js --type=full",
    "backup:incremental": "node scripts/backup.js --type=incremental",
    "backup:verify": "node scripts/backup.js --verify",
    "backup:restore": "node scripts/backup.js --restore",
    "backup:schedule": "node scripts/backup-scheduler.js",
    "backup:drill": "node scripts/backup-drill.js"
  },
  "keywords": [
    "hjtpx",
    "project"
  ],
  "author": "HJTPX Developer",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^8.0.0",
    "@sentry/profiling-node": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "node-cron": "^4.0.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "rate-limit-redis": "^5.0.0",
    "redis": "^4.6.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@playwright/test": "^1.60.0",
    "@sentry/cli": "^2.0.0",
    "@testing-library/react": "^16.3.2",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.0.0",
    "supertest": "^6.3.3"
  }
}
