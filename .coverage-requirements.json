{
  "branches": {
    "main": {
      "minimum": {
        "branches": 60,
        "functions": 60,
        "lines": 60,
        "statements": 60
      },
      "description": "Main branch requires highest coverage"
    },
    "develop": {
      "minimum": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      },
      "description": "Develop branch requires moderate coverage"
    },
    "feature/*": {
      "minimum": {
        "branches": 40,
        "functions": 40,
        "lines": 40,
        "statements": 40
      },
      "description": "Feature branches require baseline coverage"
    },
    "release/*": {
      "minimum": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      },
      "description": "Release branches require high coverage"
    },
    "hotfix/*": {
      "minimum": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      },
      "description": "Hotfix branches require baseline coverage"
    }
  },
  "global": {
    "minimum": {
      "branches": 40,
      "functions": 40,
      "lines": 40,
      "statements": 40
    },
    "dropThreshold": 5,
    "description": "Global minimum coverage requirements"
  }
}
