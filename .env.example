# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=verification
POSTGRES_SSLMODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_very_secure_jwt_secret_key_here_minimum_32_chars
JWT_EXPIRE_HOURS=24

# Server Configuration
SERVER_PORT=8080
GIN_MODE=release
SERVER_READ_TIMEOUT=60
SERVER_WRITE_TIMEOUT=60

# Security Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
XSS_PROTECTION_ENABLED=true
CSRF_PROTECTION_ENABLED=true

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_AGE=30
LOG_MAX_BACKUPS=10

# Application Configuration
APP_NAME=hjtpx
APP_ENV=production
APP_DEBUG=false

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization

# Monitoring Configuration
METRICS_ENABLED=true
METRICS_PORT=9090

# Prometheus Configuration (optional)
PROMETHEUS_ENABLED=false

# Grafana Configuration (optional)
GRAFANA_PASSWORD=admin

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30

# Feature Flags
ENABLE_SLIDER_CAPTCHA=true
ENABLE_CLICK_CAPTCHA=true
ENABLE_SILENT_VERIFICATION=true
ENABLE_DEVICE_FINGERPRINT=true
