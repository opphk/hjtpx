GIN_MODE=release
SERVER_PORT=8080

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=hjtpx_db
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=100
POSTGRES_MAX_IDLE_CONNS=20
POSTGRES_CONN_MAX_LIFETIME=300

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_MAX_RETRIES=3

JWT_SECRET=your-very-secure-jwt-secret-key-min-32-chars
JWT_EXPIRE_HOURS=24

APP_ENV=production
APP_PORT=8080
NGINX_PORT=80
NGINX_SSL_PORT=443

LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_PATH=/var/log/hjtpx/app.log

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_LIMIT=100
RATE_LIMIT_WINDOW_SECS=60
RATE_LIMIT_BURST_LIMIT=200

SECURITY_ENABLE_CSRF=true
SECURITY_ENABLE_XSS=true
SECURITY_ENABLE_SIGNATURE=true
SECURITY_SIGNATURE_EXPIRE_SECS=300
SECURITY_SIGNATURE_KEY=

CSRF_ENABLE=true
CSRF_TOKEN_LENGTH=32
CSRF_TOKEN_EXPIRATION=1h
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_FORM_FIELD=csrf_token
CSRF_COOKIE_NAME=csrf_token
CSRF_SAFE_METHODS=GET,HEAD,OPTIONS
CSRF_REQUIRE_VALIDATION=true

XSS_ENABLE_LOG=true
XSS_ALLOWED_TAGS=p,br,strong,em,u,h1,h2,h3,h4,h5,h6,ul,ol,li,a,img
XSS_BLOCK_ATTRIBUTES=false
XSS_MAX_LENGTH=10000
XSS_ENABLE_SAFE_HTML=true

SIGNATURE_ENABLE=true
SIGNATURE_SECRET_KEY=your-production-signature-secret-key
SIGNATURE_ALGORITHM=SHA256
SIGNATURE_TIMESTAMP_TOLERANCE=5m
SIGNATURE_REQUIRE_TIMESTAMP=true
SIGNATURE_REQUIRE_NONCE=true
SIGNATURE_NONCE_CACHE_TTL=24h
SIGNATURE_HEADER=X-Signature
SIGNATURE_TIMESTAMP_HEADER=X-Timestamp
SIGNATURE_NONCE_HEADER=X-Nonce

CRYPTO_AES_KEY_SIZE=32
CRYPTO_HASH_ALGORITHM=sha256
CRYPTO_PBKDF2_ITERATIONS=100000
CRYPTO_SALT_LENGTH=32
CRYPTO_ENABLE_KEY_ROTATION=false
CRYPTO_KEY_ROTATION_PERIOD=2160h

RATELIMIT_ENABLE=true
RATELIMIT_RPS=100
RATELIMIT_BURST=200
RATELIMIT_CLEANUP_INTERVAL=5m
RATELIMIT_ENABLE_PER_IP=true
RATELIMIT_ENABLE_PER_USER=true

SESSION_TIMEOUT=24h
SESSION_REFRESH_TIMEOUT=30m
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_NAME=session_id

PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_MAX_ATTEMPTS=5
PASSWORD_LOCKOUT_DURATION=30m
PASSWORD_BCRYPT_COST=12

CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization,X-CSRF-Token,X-Signature,X-Timestamp,X-Nonce
MAX_REQUEST_BODY_SIZE=10485760
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000
ENABLE_CSP=true
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.bootcdn.net; style-src 'self' 'unsafe-inline' https://cdn.bootcdn.net; font-src 'self' https://cdn.bootcdn.net; img-src 'self' data: https:; connect-src 'self';

DB_SLOW_QUERY_THRESHOLD_MS=50
DB_ENABLE_PREPARED_STATEMENTS=true
DB_ENABLE_QUERY_CACHE=true
DB_QUERY_CACHE_TTL_SECS=300
DB_MAX_QUERY_CACHE_SIZE=10000

DB_RW_SEPARATION_ENABLED=false
DB_RW_LOAD_BALANCE_STRATEGY=round_robin
DB_RW_AUTO_FAILOVER=true

DB_POOL_MAX_OPEN=150
DB_POOL_MAX_IDLE=50
DB_POOL_MAX_LIFETIME=3600
DB_POOL_MAX_IDLE_TIME=600
DB_POOL_HEALTH_CHECK=30
DB_POOL_MIN_IDLE=10
DB_POOL_WAIT_TIMEOUT=30
DB_POOL_MAX_WAIT=500
DB_POOL_WARMUP_ENABLED=true
DB_POOL_WARMUP_CONNS=10
DB_POOL_AUTO_TUNING=true
DB_POOL_HIGH_LOAD=80
DB_POOL_LOW_LOAD=20

DB_ARCHIVING_ENABLED=true
DB_ARCHIVE_THRESHOLD_DAYS=30
DB_ARCHIVE_TABLE_PREFIX=archive_
DB_AUTO_CLEANUP_ENABLED=true
DB_CLEANUP_THRESHOLD_DAYS=365

DB_AUTO_ANALYZE_ENABLED=true
DB_AUTO_ANALYZE_INTERVAL=24

DB_MONITOR_QUERIES=true
DB_MONITOR_CONNECTIONS=true
DB_METRICS_INTERVAL=60

ALERT_ENABLED=true
ALERT_DEFAULT_TIMEOUT=300
ALERT_MAX_COUNT=1000
ALERT_SLACK_ENABLED=true
ALERT_WEBHOOK_ENABLED=true

DEFAULT_LANG=zh-CN
TRANSLATIONS_DIR=translations
DEFAULT_TIMEZONE=Asia/Shanghai

BACKUP_ENABLED=true
BACKUP_DIR=./backups
BACKUP_AUTO_ENABLED=true
BACKUP_AUTO_INTERVAL_HOURS=24
BACKUP_INCREMENTAL_ENABLED=true
BACKUP_INCREMENTAL_INTERVAL_MINS=60
BACKUP_REMOTE_ENABLED=false
BACKUP_REMOTE_TYPE=s3
BACKUP_REMOTE_PATH=
BACKUP_REMOTE_ENDPOINT=
BACKUP_REMOTE_ACCESS_KEY=
BACKUP_REMOTE_SECRET_KEY=
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION_ENABLED=true
BACKUP_ENCRYPTION_ENABLED=false
BACKUP_ENCRYPTION_KEY=

CONFIG_ENCRYPTION_ENABLED=false
CONFIG_ENCRYPTION_KEY=
CONFIG_BACKUP_ENABLED=true
CONFIG_BACKUP_DIR=./config_backups
CONFIG_BACKUP_MAX_COUNT=10
CONFIG_BACKUP_COMPRESSION=true

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
