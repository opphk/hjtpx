SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=hjtpx-api
APP_VERSION=1.0.0

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

FULL_BACKUP_CRON=0 2 * * 0
INCREMENTAL_BACKUP_CRON=0 2 * * 1-6
VERIFY_BACKUP_CRON=0 3 * * 0
CLEANUP_CRON=0 4 * * 0
TIMEZONE=UTC

DRILL_ENV=staging
DRILL_DB_NAME=hjtpx_drill
DRILL_DB_HOST=localhost
DRILL_DB_PORT=5432
DRILL_DB_USER=postgres
DRILL_DB_PASSWORD=

DATABASE_ALERT_WEBHOOK=
