package redis

import (
	"container/heap"
	"context"
	"sync"
	"sync/atomic"
	"time"
)

type EvictionPolicy int

const (
	EvictionPolicyLRU EvictionPolicy = iota
	EvictionPolicyLFU
	EvictionPolicyFIFO
	EvictionPolicyTTL
	EvictionPolicyRandom
	EvictionPolicyAdaptive
)

type EvictionStats struct {
	TotalEvictions   atomic.Int64
	LRUEvictions     atomic.Int64
	LFUEvictions     atomic.Int64
	TTLEvictions     atomic.Int64
	MemoryEvictions  atomic.Int64
	CustomEvictions  atomic.Int64
	LastEvictionTime atomic.Value
}

type CacheEvictionConfig struct {
	Policy               EvictionPolicy
	MaxMemory            int64
	MaxItems             int
	MemoryCheckInterval  time.Duration
	EnableAutoTuning     bool
	EvictionBatchSize    int
	LFUMinFrequency      int64
	LRUWindowSize        time.Duration
}

var DefaultEvictionConfig = &CacheEvictionConfig{
	Policy:              EvictionPolicyLRU,
	MaxMemory:           100 * 1024 * 1024,
	MaxItems:            10000,
	MemoryCheckInterval: 1 * time.Minute,
	EnableAutoTuning:    true,
	EvictionBatchSize:   100,
	LFUMinFrequency:     10,
	LRUWindowSize:       5 * time.Minute,
}

type lruEntry struct {
	key        string
	value      []byte
	expiresAt  time.Time
	accessTime time.Time
	index      int
}

type lfuEntry struct {
	key         string
	value       []byte
	expiresAt   time.Time
	frequency   int64
	lastUpdated time.Time
	index      int
}

type lruCache struct {
	mu       sync.Mutex
	items    map[string]*lruEntry
	expiry   *priorityQueue
	maxSize  int
	evictions int64
}

type lfuCache struct {
	mu       sync.Mutex
	items    map[string]*lfuEntry
	freq     *lfuFrequencyList
	maxSize  int
	evictions int64
}

type priorityQueue []*lruEntry

func (pq priorityQueue) Len() int { return len(pq) }

func (pq priorityQueue) Less(i, j int) bool {
	return pq[i].accessTime.Before(pq[j].accessTime)
}

func (pq priorityQueue) Swap(i, j int) {
	pq[i], pq[j] = pq[i], pq[j]
	pq[i].index = i
	pq[j].index = j
}

func (pq *priorityQueue) Push(x interface{}) {
	n := len(*pq)
	item := x.(*lruEntry)
	item.index = n
	*pq = append(*pq, item)
}

func (pq *priorityQueue) Pop() interface{} {
	old := *pq
	n := len(old)
	item := old[n-1]
	old[n-1] = nil
	item.index = -1
	*pq = old[0 : n-1]
	return item
}

type lfuFrequencyList struct {
	buckets    map[int64][]*lfuEntry
	minFreq    int64
	maxFreq    int64
}

func newLFUFrequencyList() *lfuFrequencyList {
	return &lfuFrequencyList{
		buckets: make(map[int64][]*lfuEntry),
		minFreq: 0,
		maxFreq: 0,
	}
}

type EnhancedCacheEvictor struct {
	config     *CacheEvictionConfig
	stats      *EvictionStats
	policy     EvictionPolicy
	l1Cache    *lruCache
	lfuCache   *lfuCache
	adaptive   *AdaptiveEvictionPolicy
	mu         sync.RWMutex
	ctx        context.Context
	cancel     context.CancelFunc
}

func NewEnhancedCacheEvictor(config *CacheEvictionConfig) *EnhancedCacheEvictor {
	if config == nil {
		config = DefaultEvictionConfig
	}

	ctx, cancel := context.WithCancel(context.Background())

	evictor := &EnhancedCacheEvictor{
		config:   config,
		stats:    &EvictionStats{},
		policy:   config.Policy,
		l1Cache:  newLRUCache(config.MaxItems),
		lfuCache: newLFUCache(config.MaxItems),
		adaptive: NewAdaptiveEvictionPolicy(),
		ctx:      ctx,
		cancel:   cancel,
	}

	go evictor.startMemoryMonitor()

	return evictor
}

func newLRUCache(maxSize int) *lruCache {
	return &lruCache{
		items:   make(map[string]*lruEntry),
		expiry:  new(priorityQueue),
		maxSize: maxSize,
	}
}

func newLFUCache(maxSize int) *lfuCache {
	return &lfuCache{
		items:   make(map[string]*lfuEntry),
		freq:    newLFUFrequencyList(),
		maxSize: maxSize,
	}
}

func (lc *lruCache) Add(key string, value []byte, ttl time.Duration) {
	lc.mu.Lock()
	defer lc.mu.Unlock()

	if entry, exists := lc.items[key]; exists {
		entry.value = value
		entry.accessTime = time.Now()
		if ttl > 0 {
			entry.expiresAt = time.Now().Add(ttl)
		}
		heap.Fix(lc.expiry, entry.index)
		return
	}

	entry := &lruEntry{
		key:        key,
		value:      value,
		accessTime: time.Now(),
	}

	if ttl > 0 {
		entry.expiresAt = time.Now().Add(ttl)
	}

	lc.items[key] = entry
	heap.Push(lc.expiry, entry)

	if len(lc.items) > lc.maxSize {
		lc.evict()
	}
}

func (lc *lruCache) Get(key string) ([]byte, bool) {
	lc.mu.Lock()
	defer lc.mu.Unlock()

	entry, exists := lc.items[key]
	if !exists {
		return nil, false
	}

	if !entry.expiresAt.IsZero() && time.Now().After(entry.expiresAt) {
		lc.remove(key)
		return nil, false
	}

	entry.accessTime = time.Now()
	heap.Fix(lc.expiry, entry.index)

	return entry.value, true
}

func (lc *lruCache) Remove(key string) {
	lc.mu.Lock()
	defer lc.mu.Unlock()
	lc.remove(key)
}

func (lc *lruCache) remove(key string) {
	if entry, exists := lc.items[key]; exists {
		heap.Remove(lc.expiry, entry.index)
		delete(lc.items, key)
	}
}

func (lc *lruCache) evict() {
	if lc.expiry.Len() > 0 {
		entry := heap.Pop(lc.expiry).(*lruEntry)
		delete(lc.items, entry.key)
		lc.evictions++
	}
}

func (lc *lruCache) EvictExpired() int {
	lc.mu.Lock()
	defer lc.mu.Unlock()

	now := time.Now()
	evicted := 0

	for lc.expiry.Len() > 0 {
		entry := (*lc.expiry)[0]
		if entry.expiresAt.IsZero() || entry.expiresAt.After(now) {
			break
		}
		heap.Pop(lc.expiry)
		delete(lc.items, entry.key)
		evicted++
		lc.evictions++
	}

	return evicted
}

func (fc *lfuCache) Add(key string, value []byte, ttl time.Duration) {
	fc.mu.Lock()
	defer fc.mu.Unlock()

	if entry, exists := fc.items[key]; exists {
		entry.value = value
		entry.frequency++
		entry.lastUpdated = time.Now()
		if ttl > 0 {
			entry.expiresAt = time.Now().Add(ttl)
		}
		return
	}

	entry := &lfuEntry{
		key:         key,
		value:       value,
		frequency:   1,
		lastUpdated: time.Now(),
	}

	if ttl > 0 {
		entry.expiresAt = time.Now().Add(ttl)
	}

	fc.items[key] = entry
	fc.freq.buckets[1] = append(fc.freq.buckets[1], entry)
	if fc.freq.minFreq == 0 {
		fc.freq.minFreq = 1
	}
	if 1 > fc.freq.maxFreq {
		fc.freq.maxFreq = 1
	}

	if len(fc.items) > fc.maxSize {
		fc.evict()
	}
}

func (fc *lfuCache) Get(key string) ([]byte, bool) {
	fc.mu.Lock()
	defer fc.mu.Unlock()

	entry, exists := fc.items[key]
	if !exists {
		return nil, false
	}

	if !entry.expiresAt.IsZero() && time.Now().After(entry.expiresAt) {
		fc.remove(key)
		return nil, false
	}

	entry.frequency++
	entry.lastUpdated = time.Now()

	return entry.value, true
}

func (fc *lfuCache) Remove(key string) {
	fc.mu.Lock()
	defer fc.mu.Unlock()
	fc.remove(key)
}

func (fc *lfuCache) remove(key string) {
	delete(fc.items, key)
}

func (fc *lfuCache) evict() {
	if fc.freq.minFreq > 0 {
		if entries, ok := fc.freq.buckets[fc.freq.minFreq]; ok && len(entries) > 0 {
			entry := entries[0]
			fc.freq.buckets[fc.freq.minFreq] = entries[1:]
			delete(fc.items, entry.key)
			fc.evictions++
		}
	}
}

func (fc *lfuCache) EvictExpired() int {
	fc.mu.Lock()
	defer fc.mu.Unlock()

	now := time.Now()
	evicted := 0

	for key, entry := range fc.items {
		if !entry.expiresAt.IsZero() && entry.expiresAt.Before(now) {
			delete(fc.items, key)
			evicted++
			fc.evictions++
		}
	}

	return evicted
}

func (ece *EnhancedCacheEvictor) Evict(policy EvictionPolicy) int {
	ece.mu.Lock()
	defer ece.mu.Unlock()

	var evicted int

	switch policy {
	case EvictionPolicyLRU:
		evicted = int(ece.l1Cache.evictions)
	case EvictionPolicyLFU:
		evicted = int(ece.lfuCache.evictions)
	case EvictionPolicyTTL:
		evicted = ece.l1Cache.EvictExpired()
		evicted += ece.lfuCache.EvictExpired()
	case EvictionPolicyAdaptive:
		bestPolicy := ece.adaptive.GetBestPolicy()
		evicted = ece.Evict(bestPolicy)
	default:
		evicted = int(ece.l1Cache.evictions)
	}

	ece.stats.TotalEvictions.Add(int64(evicted))
	ece.stats.LastEvictionTime.Store(time.Now())

	return evicted
}

func (ece *EnhancedCacheEvictor) RecordAccess(key string, policy EvictionPolicy) {
	switch policy {
	case EvictionPolicyLRU:
		ece.l1Cache.Get(key)
	case EvictionPolicyLFU:
		ece.lfuCache.Get(key)
	case EvictionPolicyAdaptive:
		ece.adaptive.RecordAccess(key)
	}
}

func (ece *EnhancedCacheEvictor) SetPolicy(policy EvictionPolicy) {
	ece.mu.Lock()
	defer ece.mu.Unlock()
	ece.policy = policy
}

func (ece *EnhancedCacheEvictor) GetPolicy() EvictionPolicy {
	ece.mu.RLock()
	defer ece.mu.RUnlock()
	return ece.policy
}

func (ece *EnhancedCacheEvictor) startMemoryMonitor() {
	ticker := time.NewTicker(ece.config.MemoryCheckInterval)
	defer ticker.Stop()

	for {
		select {
		case <-ece.ctx.Done():
			return
		case <-ticker.C:
			ece.checkMemoryUsage()
		}
	}
}

func (ece *EnhancedCacheEvictor) checkMemoryUsage() {
}

func (ece *EnhancedCacheEvictor) GetStats() *EvictionStats {
	return ece.stats
}

func (ece *EnhancedCacheEvictor) Close() {
	ece.cancel()
}

type AdaptiveEvictionPolicy struct {
	mu             sync.RWMutex
	accessPatterns map[string]*EvictionAccessPattern
	metrics        *PolicyMetrics
	bestPolicy     EvictionPolicy
}

type EvictionAccessPattern struct {
	Key           string
	AccessCount   int64
	LastAccess    time.Time
	Frequency     float64
	RecencyScore  float64
}

type PolicyMetrics struct {
	LRUHits    int64
	LFUHits    int64
	FIFOHits   int64
	TTLHits    int64
	TotalHits  int64
}

func NewAdaptiveEvictionPolicy() *AdaptiveEvictionPolicy {
	return &AdaptiveEvictionPolicy{
		accessPatterns: make(map[string]*EvictionAccessPattern),
		metrics:        &PolicyMetrics{},
		bestPolicy:     EvictionPolicyLRU,
	}
}

func (aep *AdaptiveEvictionPolicy) RecordAccess(key string) {
	aep.mu.Lock()
	defer aep.mu.Unlock()

	pattern, exists := aep.accessPatterns[key]
	if !exists {
		pattern = &EvictionAccessPattern{
			Key:        key,
			LastAccess: time.Now(),
		}
		aep.accessPatterns[key] = pattern
	}

	pattern.AccessCount++
	pattern.LastAccess = time.Now()
	pattern.Frequency = float64(pattern.AccessCount) / time.Since(time.Now().Add(-24*time.Hour)).Seconds()
	pattern.RecencyScore = 1.0 - float64(time.Since(pattern.LastAccess).Seconds())/86400.0

	aep.recalculateBestPolicy()
}

func (aep *AdaptiveEvictionPolicy) recalculateBestPolicy() {
	lruScore := 0.0
	lfuScore := 0.0

	for _, pattern := range aep.accessPatterns {
		lruScore += pattern.RecencyScore
		lfuScore += pattern.Frequency
	}

	if lfuScore > lruScore {
		aep.bestPolicy = EvictionPolicyLFU
	} else {
		aep.bestPolicy = EvictionPolicyLRU
	}
}

func (aep *AdaptiveEvictionPolicy) GetBestPolicy() EvictionPolicy {
	aep.mu.RLock()
	defer aep.mu.RUnlock()
	return aep.bestPolicy
}

func (aep *AdaptiveEvictionPolicy) ShouldEvict(key string) bool {
	aep.mu.RLock()
	defer aep.mu.RUnlock()

	if pattern, exists := aep.accessPatterns[key]; exists {
		return pattern.RecencyScore < 0.3
	}
	return true
}

func (aep *AdaptiveEvictionPolicy) GetPattern(key string) *EvictionAccessPattern {
	aep.mu.RLock()
	defer aep.mu.RUnlock()
	return aep.accessPatterns[key]
}

func (aep *AdaptiveEvictionPolicy) Cleanup() {
	aep.mu.Lock()
	defer aep.mu.Unlock()

	cutoff := time.Now().Add(-24 * time.Hour)
	for key, pattern := range aep.accessPatterns {
		if pattern.LastAccess.Before(cutoff) {
			delete(aep.accessPatterns, key)
		}
	}
}

type EvictionStrategy struct {
	evictor     *EnhancedCacheEvictor
	policy      EvictionPolicy
	cooldown    time.Duration
	lastEvict   time.Time
}

func NewEvictionStrategy(policy EvictionPolicy) *EvictionStrategy {
	return &EvictionStrategy{
		evictor:  NewEnhancedCacheEvictor(nil),
		policy:   policy,
		cooldown: 1 * time.Second,
	}
}

func (es *EvictionStrategy) ShouldEvict() bool {
	if time.Since(es.lastEvict) < es.cooldown {
		return false
	}

	es.lastEvict = time.Now()
	return true
}

func (es *EvictionStrategy) SetCooldown(duration time.Duration) {
	es.cooldown = duration
}

func (es *EvictionStrategy) SetPolicy(policy EvictionPolicy) {
	es.policy = policy
	es.evictor.SetPolicy(policy)
}

var (
	globalCacheEvictor     *EnhancedCacheEvictor
	globalCacheEvictorOnce  sync.Once
)

func InitCacheEvictor(config *CacheEvictionConfig) {
	globalCacheEvictorOnce.Do(func() {
		globalCacheEvictor = NewEnhancedCacheEvictor(config)
	})
}

func GetCacheEvictor() *EnhancedCacheEvictor {
	if globalCacheEvictor == nil {
		InitCacheEvictor(nil)
	}
	return globalCacheEvictor
}

func EvictCache(policy EvictionPolicy) int {
	return GetCacheEvictor().Evict(policy)
}

func RecordCacheAccess(key string, policy EvictionPolicy) {
	GetCacheEvictor().RecordAccess(key, policy)
}
