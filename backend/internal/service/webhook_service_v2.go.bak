package service

import (
	"bytes"
	"context"
	"crypto/hmac"
	"crypto/sha256"
	"encoding/base64"
	"encoding/hex"
	"encoding/json"
	"fmt"
	"io"
	"net/http"
	"sync"
	"time"

	"github.com/hjtpx/hjtpx/internal/pkg/logger"
	"github.com/hjtpx/hjtpx/pkg/redis"
)

var (
	ErrWebhookDeliveryFailed   = fmt.Errorf("webhook delivery failed")
	ErrWebhookInvalidSignature = fmt.Errorf("invalid webhook signature")
	ErrWebhookTimeout         = fmt.Errorf("webhook delivery timeout")
)

type WebhookEventType string

const (
	EventVerificationSuccess WebhookEventType = "verification.success"
	EventVerificationFailed  WebhookEventType = "verification.failed"
	EventCaptchaCreated      WebhookEventType = "captcha.created"
	EventCaptchaExpired      WebhookEventType = "captcha.expired"
	EventRiskDetected       WebhookEventType = "risk.detected"
	EventSecurityAlert      WebhookEventType = "security.alert"
	EventUserRegistered     WebhookEventType = "user.registered"
	EventUserLogin          WebhookEventType = "user.login"
	EventUserLogout         WebhookEventType = "user.logout"
	EventAdminAction        WebhookEventType = "admin.action"
)

type WebhookPayload struct {
	Event     WebhookEventType       `json:"event"`
	Timestamp time.Time              `json:"timestamp"`
	ID        string                 `json:"id"`
	Data      map[string]interface{} `json:"data"`
	Metadata  WebhookMetadata         `json:"metadata,omitempty"`
}

type WebhookMetadata struct {
	IPAddress   string `json:"ip_address,omitempty"`
	UserAgent   string `json:"user_agent,omitempty"`
	RequestID   string `json:"request_id,omitempty"`
	Application string `json:"application,omitempty"`
}

type WebhookEndpoint struct {
	ID          string                 `json:"id"`
	Name        string                 `json:"name"`
	URL         string                 `json:"url"`
	Secret      string                 `json:"secret"`
	EventTypes  []WebhookEventType     `json:"event_types"`
	Headers     map[string]string      `json:"headers,omitempty"`
	Timeout     time.Duration          `json:"timeout,omitempty"`
	RetryPolicy *WebhookRetryPolicy    `json:"retry_policy,omitempty"`
	Active      bool                   `json:"active"`
	CreatedAt   time.Time              `json:"created_at"`
	UpdatedAt   time.Time              `json:"updated_at"`
}

type WebhookRetryPolicy struct {
	MaxRetries     int           `json:"max_retries"`
	InitialDelay   time.Duration `json:"initial_delay"`
	MaxDelay       time.Duration `json:"max_delay"`
	BackoffFactor  float64       `json:"backoff_factor"`
	RetryableCodes []int         `json:"retryable_codes,omitempty"`
}

type WebhookDelivery struct {
	ID           string                 `json:"id"`
	EndpointID   string                 `json:"endpoint_id"`
	Event        WebhookEventType       `json:"event"`
	Payload      *WebhookPayload        `json:"payload"`
	Attempts     int                    `json:"attempts"`
	Status       string                 `json:"status"`
	ResponseCode int                    `json:"response_code,omitempty"`
	ResponseBody string                 `json:"response_body,omitempty"`
	Error        string                 `json:"error,omitempty"`
	CreatedAt    time.Time              `json:"created_at"`
	DeliveredAt  *time.Time             `json:"delivered_at,omitempty"`
	NextRetryAt  *time.Time             `json:"next_retry_at,omitempty"`
}

type WebhookServiceV2 struct {
	endpoints    map[string]*WebhookEndpoint
	deliveries   map[string]*WebhookDelivery
	signatureKey []byte
	mu           sync.RWMutex
	logger       *logger.Logger
	client       *http.Client
}

var webhookServiceV2 *WebhookServiceV2
var webhookOnce sync.Once

func GetWebhookServiceV2() *WebhookServiceV2 {
	webhookOnce.Do(func() {
		webhookServiceV2 = &WebhookServiceV2{
			endpoints:  make(map[string]*WebhookEndpoint),
			deliveries: make(map[string]*WebhookDelivery),
			signatureKey: []byte(getWebhookSignatureKey()),
			logger:     logger.Default(),
			client: &http.Client{
				Timeout: 30 * time.Second,
				Transport: &http.Transport{
					MaxIdleConns:        100,
					MaxIdleConnsPerHost: 10,
					IdleConnTimeout:     90 * time.Second,
				},
			},
		}
	})
	return webhookServiceV2
}

func getWebhookSignatureKey() string {
	return "webhook-signature-key-change-in-production"
}

func (s *WebhookServiceV2) RegisterEndpoint(endpoint *WebhookEndpoint) error {
	s.mu.Lock()
	defer s.mu.Unlock()

	if endpoint.ID == "" {
		endpoint.ID = generateWebhookID()
	}
	if endpoint.Timeout == 0 {
		endpoint.Timeout = 10 * time.Second
	}
	if endpoint.RetryPolicy == nil {
		endpoint.RetryPolicy = &WebhookRetryPolicy{
			MaxRetries:    3,
			InitialDelay:  time.Second,
			MaxDelay:      60 * time.Second,
			BackoffFactor: 2.0,
			RetryableCodes: []int{408, 429, 500, 502, 503, 504},
		}
	}
	if endpoint.Active {
		endpoint.Active = true
	}

	endpoint.CreatedAt = time.Now()
	endpoint.UpdatedAt = time.Now()

	s.endpoints[endpoint.ID] = endpoint
	s.logger.Info("Webhook endpoint registered", "id", endpoint.ID, "url", endpoint.URL)

	return nil
}

func (s *WebhookServiceV2) UnregisterEndpoint(endpointID string) {
	s.mu.Lock()
	defer s.mu.Unlock()
	delete(s.endpoints, endpointID)
	s.logger.Log(logger.INFO, "Webhook endpoint unregistered", logger.Fields{"id": endpointID})
}

func (s *WebhookServiceV2) GetEndpoint(endpointID string) (*WebhookEndpoint, error) {
	s.mu.RLock()
	defer s.mu.RUnlock()

	endpoint, exists := s.endpoints[endpointID]
	if !exists {
		return nil, fmt.Errorf("webhook endpoint not found")
	}
	return endpoint, nil
}

func (s *WebhookServiceV2) ListEndpoints() []*WebhookEndpoint {
	s.mu.RLock()
	defer s.mu.RUnlock()

	endpoints := make([]*WebhookEndpoint, 0, len(s.endpoints))
	for _, endpoint := range s.endpoints {
		endpoints = append(endpoints, endpoint)
	}
	return endpoints
}

func (s *WebhookServiceV2) UpdateEndpoint(endpointID string, updates map[string]interface{}) error {
	s.mu.Lock()
	defer s.mu.Unlock()

	endpoint, exists := s.endpoints[endpointID]
	if !exists {
		return fmt.Errorf("webhook endpoint not found")
	}

	if url, ok := updates["url"].(string); ok {
		endpoint.URL = url
	}
	if secret, ok := updates["secret"].(string); ok {
		endpoint.Secret = secret
	}
	if headers, ok := updates["headers"].(map[string]string); ok {
		endpoint.Headers = headers
	}
	if timeout, ok := updates["timeout"].(float64); ok {
		endpoint.Timeout = time.Duration(timeout)
	}
	if active, ok := updates["active"].(bool); ok {
		endpoint.Active = active
	}
	if eventTypes, ok := updates["event_types"].([]interface{}); ok {
		for _, et := range eventTypes {
			if etStr, ok := et.(string); ok {
				endpoint.EventTypes = append(endpoint.EventTypes, WebhookEventType(etStr))
			}
		}
	}

	endpoint.UpdatedAt = time.Now()
	return nil
}

func (s *WebhookServiceV2) TriggerEvent(eventType WebhookEventType, data map[string]interface{}, metadata *WebhookMetadata) error {
	s.mu.RLock()
	defer s.mu.RUnlock()

	var wg sync.WaitGroup
	var deliveryErrors []error

	for _, endpoint := range s.endpoints {
		if !endpoint.Active {
			continue
		}

		if !s.shouldDeliverToEndpoint(endpoint, eventType) {
			continue
		}

		wg.Add(1)
		go func(ep *WebhookEndpoint) {
			defer wg.Done()

			delivery := &WebhookDelivery{
				ID:         generateWebhookID(),
				EndpointID: ep.ID,
				Event:      eventType,
				CreatedAt:  time.Now(),
			}

			payload := &WebhookPayload{
				Event:     eventType,
				Timestamp: time.Now(),
				ID:        delivery.ID,
				Data:      data,
			}

			if metadata != nil {
				payload.Metadata = *metadata
			}

			delivery.Payload = payload

			err := s.deliverWithRetry(ep, delivery)
			if err != nil {
				s.mu.Lock()
				s.deliveries[delivery.ID] = delivery
				s.mu.Unlock()
				deliveryErrors = append(deliveryErrors, err)
				s.logger.Error("Webhook delivery failed", "endpoint", ep.ID, "error", err)
			} else {
				s.mu.Lock()
				s.deliveries[delivery.ID] = delivery
				s.mu.Unlock()
				s.logger.Log(logger.INFO, "Webhook delivered successfully", logger.Fields{"endpoint": ep.ID, "delivery_id": delivery.ID})
			}
		}(endpoint)
	}

	wg.Wait()

	if len(deliveryErrors) > 0 {
		return fmt.Errorf("webhook delivery failed for %d endpoints", len(deliveryErrors))
	}

	return nil
}

func (s *WebhookServiceV2) shouldDeliverToEndpoint(endpoint *WebhookEndpoint, eventType WebhookEventType) bool {
	if len(endpoint.EventTypes) == 0 {
		return true
	}

	for _, et := range endpoint.EventTypes {
		if et == eventType {
			return true
		}
	}
	return false
}

func (s *WebhookServiceV2) deliverWithRetry(endpoint *WebhookEndpoint, delivery *WebhookDelivery) error {
	var lastErr error
	maxRetries := endpoint.RetryPolicy.MaxRetries
	delay := endpoint.RetryPolicy.InitialDelay

	for attempt := 0; attempt <= maxRetries; attempt++ {
		delivery.Attempts = attempt + 1

		err := s.deliver(endpoint, delivery)
		if err == nil {
			now := time.Now()
			delivery.Status = "delivered"
			delivery.DeliveredAt = &now
			return nil
		}

		lastErr = err
		delivery.Error = err.Error()

		if attempt < maxRetries {
			shouldRetry := s.shouldRetry(err, endpoint.RetryPolicy)
			if !shouldRetry {
				break
			}

			delivery.NextRetryAt = new(time.Time)
			*delivery.NextRetryAt = time.Now().Add(delay)

			time.Sleep(delay)

			delay = time.Duration(float64(delay) * endpoint.RetryPolicy.BackoffFactor)
			if delay > endpoint.RetryPolicy.MaxDelay {
				delay = endpoint.RetryPolicy.MaxDelay
			}
		}
	}

	delivery.Status = "failed"
	return lastErr
}

func (s *WebhookServiceV2) shouldRetry(err error, policy *WebhookRetryPolicy) bool {
	return true
}

func (s *WebhookServiceV2) deliver(endpoint *WebhookEndpoint, delivery *WebhookDelivery) error {
	jsonPayload, err := json.Marshal(delivery.Payload)
	if err != nil {
		return fmt.Errorf("failed to marshal payload: %w", err)
	}

	req, err := http.NewRequest("POST", endpoint.URL, bytes.NewBuffer(jsonPayload))
	if err != nil {
		return fmt.Errorf("failed to create request: %w", err)
	}

	req.Header.Set("Content-Type", "application/json")
	req.Header.Set("X-Webhook-ID", delivery.ID)
	req.Header.Set("X-Webhook-Event", string(delivery.Event))
	req.Header.Set("X-Webhook-Timestamp", fmt.Sprintf("%d", time.Now().Unix()))

	signature := s.generateSignature(delivery.Payload.Timestamp, jsonPayload, endpoint.Secret)
	req.Header.Set("X-Webhook-Signature", signature)

	for key, value := range endpoint.Headers {
		req.Header.Set(key, value)
	}

	client := &http.Client{Timeout: endpoint.Timeout}
	resp, err := client.Do(req)
	if err != nil {
		return fmt.Errorf("%w: %v", ErrWebhookDeliveryFailed, err)
	}
	defer resp.Body.Close()

	delivery.ResponseCode = resp.StatusCode

	body, _ := io.ReadAll(io.LimitReader(resp.Body, 1024))
	delivery.ResponseBody = string(body)

	if resp.StatusCode < 200 || resp.StatusCode >= 300 {
		return fmt.Errorf("%w: status %d", ErrWebhookDeliveryFailed, resp.StatusCode)
	}

	return nil
}

func (s *WebhookServiceV2) generateSignature(timestamp time.Time, payload []byte, secret string) string {
	signedContent := fmt.Sprintf("%d.%s", timestamp.Unix(), string(payload))
	h := hmac.New(sha256.New, []byte(secret))
	h.Write([]byte(signedContent))
	return "sha256=" + hex.EncodeToString(h.Sum(nil))
}

func (s *WebhookServiceV2) VerifySignature(endpointID string, signature string, timestamp string, payload []byte) bool {
	endpoint, err := s.GetEndpoint(endpointID)
	if err != nil {
		return false
	}

	if endpoint.Secret == "" {
		return false
	}

	signedContent := timestamp + "." + string(payload)
	h := hmac.New(sha256.New, []byte(endpoint.Secret))
	h.Write([]byte(signedContent))
	expectedSignature := "sha256=" + hex.EncodeToString(h.Sum(nil))

	return hmac.Equal([]byte(expectedSignature), []byte(signature))
}

func (s *WebhookServiceV2) GetDelivery(deliveryID string) (*WebhookDelivery, error) {
	s.mu.RLock()
	defer s.mu.RUnlock()

	delivery, exists := s.deliveries[deliveryID]
	if !exists {
		return nil, fmt.Errorf("webhook delivery not found")
	}
	return delivery, nil
}

func (s *WebhookServiceV2) ListDeliveries(endpointID string, limit int) []*WebhookDelivery {
	s.mu.RLock()
	defer s.mu.RUnlock()

	var deliveries []*WebhookDelivery
	count := 0
	for _, delivery := range s.deliveries {
		if endpointID == "" || delivery.EndpointID == endpointID {
			deliveries = append(deliveries, delivery)
			count++
			if limit > 0 && count >= limit {
				break
			}
		}
	}
	return deliveries
}

func (s *WebhookServiceV2) RetryDelivery(deliveryID string) error {
	s.mu.RLock()
	defer s.mu.RUnlock()

	delivery, exists := s.deliveries[deliveryID]
	if !exists {
		return fmt.Errorf("webhook delivery not found")
	}

	if delivery.Status == "delivered" {
		return fmt.Errorf("delivery already successful")
	}

	endpoint, err := s.GetEndpoint(delivery.EndpointID)
	if err != nil {
		return err
	}

	s.mu.RUnlock()
	err = s.deliverWithRetry(endpoint, delivery)
	s.mu.RLock()

	if err != nil {
		delivery.Status = "failed"
		return err
	}

	delivery.Status = "delivered"
	now := time.Now()
	delivery.DeliveredAt = &now

	return nil
}

func (s *WebhookServiceV2) TestEndpoint(endpointID string) (*WebhookDelivery, error) {
	endpoint, err := s.GetEndpoint(endpointID)
	if err != nil {
		return nil, err
	}

	testPayload := &WebhookPayload{
		Event:     EventVerificationSuccess,
		Timestamp: time.Now(),
		ID:        generateWebhookID(),
		Data: map[string]interface{}{
			"test":     true,
			"message":  "This is a test webhook delivery",
			"endpoint": endpoint.URL,
		},
	}

	delivery := &WebhookDelivery{
		ID:         testPayload.ID,
		EndpointID: endpointID,
		Event:      testPayload.Event,
		Payload:    testPayload,
		CreatedAt:  time.Now(),
	}

	err = s.deliver(endpoint, delivery)
	if err != nil {
		delivery.Status = "failed"
		delivery.Error = err.Error()
	} else {
		delivery.Status = "delivered"
		now := time.Now()
		delivery.DeliveredAt = &now
	}

	s.mu.Lock()
	s.deliveries[delivery.ID] = delivery
	s.mu.Unlock()

	return delivery, nil
}

func generateWebhookID() string {
	timestamp := time.Now().UnixNano()
	b := make([]byte, 16)
	redis.Rand().Read(b)
	return fmt.Sprintf("wh_%d_%x", timestamp, b[:8])
}

func (s *WebhookServiceV2) SetSignatureKey(key string) {
	s.mu.Lock()
	defer s.mu.Unlock()
	s.signatureKey = []byte(key)
}

func (s *WebhookServiceV2) GetStats() map[string]interface{} {
	s.mu.RLock()
	defer s.mu.RUnlock()

	stats := map[string]interface{}{
		"total_endpoints":    len(s.endpoints),
		"active_endpoints":   0,
		"total_deliveries":   len(s.deliveries),
		"delivered":          0,
		"failed":             0,
		"pending":            0,
	}

	for _, ep := range s.endpoints {
		if ep.Active {
			stats["active_endpoints"] = stats["active_endpoints"].(int) + 1
		}
	}

	for _, delivery := range s.deliveries {
		switch delivery.Status {
		case "delivered":
			stats["delivered"] = stats["delivered"].(int) + 1
		case "failed":
			stats["failed"] = stats["failed"].(int) + 1
		default:
			stats["pending"] = stats["pending"].(int) + 1
		}
	}

	return stats
}

func (s *WebhookServiceV2) CleanupOldDeliveries(olderThan time.Duration) int {
	s.mu.Lock()
	defer s.mu.Unlock()

	cutoff := time.Now().Add(-olderThan)
	count := 0

	for id, delivery := range s.deliveries {
		if delivery.CreatedAt.Before(cutoff) && delivery.Status == "delivered" {
			delete(s.deliveries, id)
			count++
		}
	}

	return count
}
