	p1 := BehaviorDataPoint{X: 10, Y: 10, Timestamp: 10}
	p2 := BehaviorDataPoint{X: 20, Y: 20, Timestamp: 20}
	p3 := BehaviorDataPoint{X: 30, Y: 30, Timestamp: 30}

	points := service.computeControlPoints(p0, p1, p2, p3)

