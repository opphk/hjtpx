func TestApplyMLModel(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	result := &EnhancedVerificationResult{
		BiometricAnalysis: BiometricFeature{
			OverallScore: 0.3,
		},
		NetworkAnalysis: NetworkBehaviorAnalysis{
			BotLikelihoodScore: 70,
		},
		CrossDeviceTracking: CrossDeviceTracking{
			SuspicionScore: 60,
		},
	}

	config := &MLModelConfig{
		BiometricWeight:    0.4,
		NetworkWeight:      0.3,
		CrossDeviceWeight:  0.3,
		BotThreshold:       50.0,
		ConfidenceThreshold: 0.7,
	}

	adjusted := service.ApplyMLModel(result, config)

	if adjusted.CombinedRiskScore < 0 || adjusted.CombinedRiskScore > 100 {
		t.Error("Combined risk score should be between 0 and 100")
	}
}

