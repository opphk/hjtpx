func TestAnalyzeEnhanced(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	behaviorData := []models.BehaviorData{}
	baseTime := time.Now()

	for i := 0; i < 20; i++ {
		point := BehaviorDataPoint{
			X:         100 + i*10,
			Y:         200 + int(20*math.Sin(float64(i)/5)),
			Timestamp: baseTime.Add(time.Duration(i*50+i%10*20) * time.Millisecond).UnixMilli(),
			Event:     "move",
		}
		dataBytes, _ := json.Marshal(point)
		behaviorData = append(behaviorData, models.BehaviorData{
			DataType:  "move",
			Data:      string(dataBytes),
			Timestamp: baseTime.Add(time.Duration(i*50+i%10*20) * time.Millisecond),
		})
	}

	networkData := map[string]interface{}{
		"requests": []interface{}{
			map[string]interface{}{"timestamp": float64(1000)},
			map[string]interface{}{"timestamp": float64(1150)},
			map[string]interface{}{"timestamp": float64(1300)},
		},
	}

	deviceData := map[string]interface{}{
		"user_id": "user123",
		"user_agent": "Mozilla/5.0",
	}

	result, err := service.AnalyzeEnhanced(behaviorData, networkData, deviceData)

	if err != nil {
		t.Fatalf("AnalyzeEnhanced returned error: %v", err)
	}

	if result == nil {
		t.Fatal("Result should not be nil")
	}

	if result.CombinedRiskScore < 0 || result.CombinedRiskScore > 100 {
		t.Error("Combined risk score should be between 0 and 100")
	}
}

func TestGenerateEnhancedReportFull(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	result := &EnhancedVerificationResult{
		CombinedRiskScore: 65,
		IsBot:             true,
		BotConfidence:     75,
		BiometricAnalysis: BiometricFeature{
			OverallScore:     0.3,
			IsHumanLike:     false,
			MouseMovement: MouseBiometricFeatures{
				MovementEntropy:     2.5,
				BezierCurveFitting:  0.9,
				TrajectoryComplexity: 0.1,
			},
			KeyboardInput: KeyboardBiometricFeatures{
				TypingRhythm: TypingRhythm{
					PatternType:     "fast",
					MeanInterval:    80,
				},
			},
			TouchBehavior: TouchBiometricFeatures{
				SwipeVelocity: 3.0,
			},
		},
		DeviceBehavior: DeviceBehaviorPattern{
			IsConsistent: false,
			SessionPatterns: []SessionPattern{
				{SessionID: "session1"},
			},
			AnomalyDetection: AnomalyDetectionResult{
				IsAnomalous: true,
				AnomalyType: "bot_behavior",
				Severity:    "high",
				AnomalyScore: 70,
			},
		},
		NetworkAnalysis: NetworkBehaviorAnalysis{
			BotLikelihoodScore: 60,
			RequestTiming: RequestTimingAnalysis{
				InterRequestInterval: InterRequestInterval{
					IsTooRegular: true,
				},
			},
			TCPIPFeatures: TCPIPFeatureAnalysis{
				IsSuspicious: true,
			},
			NetworkQuality: NetworkQualityAssessment{
				QualityGrade: "excellent",
			},
		},
		CrossDeviceTracking: CrossDeviceTracking{
			IsSuspiciousSwitch: true,
			SuspicionScore:     55,
			DeviceAssociations: []DeviceAssociation{
				{DeviceID: "device1"},
			},
			BehaviorConsistency: BehaviorConsistency{
				OverallConsistency: 0.4,
			},
		},
		RiskFactors: map[string]float64{
			"biometric":       70,
			"device_behavior":  65,
			"network":         60,
			"cross_device":    55,
		},
		Recommendations: []string{
			"建议进行额外的验证挑战",
		},
		DetectionMethods: []string{
			"mouse_biometric_analysis",
			"keyboard_biometric_analysis",
		},
	}

	report := service.GenerateEnhancedReport(result)

	if len(report) == 0 {
		t.Error("Report should not be empty")
	}

	if len(report) < 100 {
		t.Error("Report should contain substantial content")
	}
}
