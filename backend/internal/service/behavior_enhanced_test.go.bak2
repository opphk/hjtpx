package service

import (
	"encoding/json"
	"fmt"
	"math"
	"sync"
	"testing"
	"time"

	"github.com/hjtpx/hjtpx/pkg/models"
)

func TestNewEnhancedBehaviorAnalysisService(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()
	if service == nil {
		t.Fatal("NewEnhancedBehaviorAnalysisService returned nil")
	}
	if service.deviceProfiles == nil {
		t.Error("deviceProfiles not initialized")
	}
	if service.networkBaseline == nil {
		t.Error("networkBaseline not initialized")
	}
	if service.crossDeviceHistory == nil {
		t.Error("crossDeviceHistory not initialized")
	}
	if len(service.humanTypingTemplates) == 0 {
		t.Error("humanTypingTemplates not initialized")
	}
	if len(service.humanMovementTemplates) == 0 {
		t.Error("humanMovementTemplates not initialized")
	}
	if len(service.knownBotPatterns) == 0 {
		t.Error("knownBotPatterns not initialized")
	}
}

func TestAnalyzeBiometricFeatures_Mouse(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	behaviorData := []models.BehaviorData{}
	baseTime := time.Now()

	for i := 0; i < 50; i++ {
		point := BehaviorDataPoint{
			X:         100 + i*10,
			Y:         150 + int(float64(i)*math.Sin(float64(i)/5)),
			Timestamp: baseTime.Add(time.Duration(i*50) * time.Millisecond).UnixMilli(),
			Event:     "move",
		}
		dataBytes, _ := json.Marshal(point)
		behaviorData = append(behaviorData, models.BehaviorData{
			DataType: "mouse",
			Data:     string(dataBytes),
			Timestamp: baseTime.Add(time.Duration(i*50) * time.Millisecond),
		})
	}

	result := service.analyzeBiometricFeatures(behaviorData)

	if result.OverallScore < 0 || result.OverallScore > 1 {
		t.Errorf("OverallScore out of range: %f", result.OverallScore)
	}

	if result.MouseMovement.MovementEntropy <= 0 {
		t.Logf("Movement entropy: %f", result.MouseMovement.MovementEntropy)
	}

	if result.MouseMovement.BezierCurveFitting < 0 || result.MouseMovement.BezierCurveFitting > 1 {
		t.Error("Bezier curve fitting should be between 0 and 1")
	}
}

func TestAnalyzeBiometricFeatures_Keyboard(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	behaviorData := []models.BehaviorData{}
	baseTime := time.Now()

	keyStrokes := []string{"t", "e", "s", "t", " ", "k", "e", "y"}
	for i, key := range keyStrokes {
		kp := KeyboardDataPoint{
			Key:       key,
			Timestamp: baseTime.Add(time.Duration(i*150+50*i*i/10) * time.Millisecond).UnixMilli(),
			KeyDownTime: baseTime.Add(time.Duration(i*150) * time.Millisecond).UnixMilli(),
			KeyUpTime: baseTime.Add(time.Duration(i*150+80) * time.Millisecond).UnixMilli(),
			HoldDuration: 80,
		}
		dataBytes, _ := json.Marshal(kp)
		behaviorData = append(behaviorData, models.BehaviorData{
			DataType: "keyboard",
			Data:     string(dataBytes),
			Timestamp: baseTime.Add(time.Duration(i*150) * time.Millisecond),
		})
	}

	result := service.analyzeBiometricFeatures(behaviorData)

	if result.KeyboardInput.TypingRhythm.MeanInterval < 0 {
		t.Error("Mean interval should be non-negative")
	}

	if result.KeyboardInput.TypingRhythm.ConsistencyScore < 0 || result.KeyboardInput.TypingRhythm.ConsistencyScore > 1 {
		t.Error("Consistency score should be between 0 and 1")
	}
}

func TestAnalyzeBiometricFeatures_Touch(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	behaviorData := []models.BehaviorData{}
	baseTime := time.Now()

	for i := 0; i < 30; i++ {
		te := TouchEvent{
			X:         200 + float64(i*5),
			Y:         300 + float64(i*3),
			Timestamp: baseTime.Add(time.Duration(i*30) * time.Millisecond).UnixMilli(),
			EventType: "swipe",
			Pressure:  0.5 + 0.3*math.Sin(float64(i)/3),
		}
		dataBytes, _ := json.Marshal(te)
		behaviorData = append(behaviorData, models.BehaviorData{
			DataType: "touch",
			Data:     string(dataBytes),
			Timestamp: baseTime.Add(time.Duration(i*30) * time.Millisecond),
		})
	}

	result := service.analyzeBiometricFeatures(behaviorData)

	if result.TouchBehavior.SwipeVelocity < 0 {
		t.Error("Swipe velocity should be non-negative")
	}

	if result.TouchBehavior.MultiTouchPattern == "" {
		t.Error("Multi-touch pattern should be set")
	}
}

func TestAnalyzeMouseBiometrics(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	points := []BehaviorDataPoint{}
	baseTime := time.Now().UnixMilli()

	for i := 0; i < 100; i++ {
		points = append(points, BehaviorDataPoint{
			X:         100 + i*5,
			Y:         200 + int(20*math.Sin(float64(i)/10)),
			Timestamp: baseTime + int64(i*40),
			Event:     "move",
		})
	}

	features := service.analyzeMouseBiometrics(points)

	if features.MovementEntropy < 0 {
		t.Error("Movement entropy should be non-negative")
	}

	if features.BezierCurveFitting < 0 || features.BezierCurveFitting > 1 {
		t.Error("Bezier curve fitting should be between 0 and 1")
	}

	if features.TrajectoryComplexity < 0 || features.TrajectoryComplexity > 1 {
		t.Error("Trajectory complexity should be between 0 and 1")
	}
}

func TestCalculateMovementEntropy(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	points := []BehaviorDataPoint{
		{X: 0, Y: 0, Timestamp: 0},
		{X: 10, Y: 10, Timestamp: 50},
		{X: 20, Y: 20, Timestamp: 100},
		{X: 30, Y: 10, Timestamp: 150},
		{X: 40, Y: 0, Timestamp: 200},
	}

	entropy := service.calculateMovementEntropy(points)
	if entropy < 0 {
		t.Error("Entropy should be non-negative")
	}

	randomPoints := []BehaviorDataPoint{}
	for i := 0; i < 50; i++ {
		randomPoints = append(randomPoints, BehaviorDataPoint{
			X:         i * 10,
			Y:         int(100 * math.Sin(float64(i))),
			Timestamp: int64(i * 50),
		})
	}
	randomEntropy := service.calculateMovementEntropy(randomPoints)
	if randomEntropy <= entropy {
		t.Logf("Random entropy: %f, structured entropy: %f", randomEntropy, entropy)
	}
}

func TestQuantizeDirection(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	testCases := []struct {
		angle    float64
		expected string
	}{
		{0, "E"},
		{math.Pi / 4, "NE"},
		{math.Pi / 2, "N"},
		{3 * math.Pi / 4, "NW"},
		{math.Pi, "W"},
		{5 * math.Pi / 4, "SW"},
		{3 * math.Pi / 2, "S"},
		{7 * math.Pi / 4, "SE"},
	}

	for _, tc := range testCases {
		result := service.quantizeDirection(tc.angle)
		if result != tc.expected {
			t.Errorf("quantizeDirection(%f) = %s, expected %s", tc.angle, result, tc.expected)
		}
	}
}

func TestCalculateBezierCurveFitting(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	points := []BehaviorDataPoint{
		{X: 0, Y: 0, Timestamp: 0},
		{X: 10, Y: 10, Timestamp: 10},
		{X: 20, Y: 20, Timestamp: 20},
		{X: 30, Y: 30, Timestamp: 30},
		{X: 40, Y: 40, Timestamp: 40},
	}

	fitting := service.calculateBezierCurveFitting(points)
	if fitting < 0 || fitting > 1 {
		t.Errorf("Bezier fitting score should be between 0 and 1, got %f", fitting)
	}

	insufficientPoints := []BehaviorDataPoint{
		{X: 0, Y: 0, Timestamp: 0},
		{X: 10, Y: 10, Timestamp: 10},
	}
	fitting = service.calculateBezierCurveFitting(insufficientPoints)
	if fitting != 0 {
		t.Errorf("Bezier fitting for insufficient points should be 0, got %f", fitting)
	}
}

func TestCalculateTrajectoryComplexity(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	straightLine := []BehaviorDataPoint{
		{X: 0, Y: 0, Timestamp: 0},
		{X: 10, Y: 10, Timestamp: 50},
		{X: 20, Y: 20, Timestamp: 100},
		{X: 30, Y: 30, Timestamp: 150},
	}
	straightComplexity := service.calculateTrajectoryComplexity(straightLine)

	curvedPath := []BehaviorDataPoint{
		{X: 0, Y: 0, Timestamp: 0},
		{X: 10, Y: 20, Timestamp: 50},
		{X: 20, Y: 10, Timestamp: 100},
		{X: 30, Y: 30, Timestamp: 150},
	}
	curvedComplexity := service.calculateTrajectoryComplexity(curvedPath)

	if curvedComplexity <= straightComplexity {
		t.Logf("Curved complexity: %f, Straight complexity: %f", curvedComplexity, straightComplexity)
	}
}

func TestCalculateMicroMovementRatio(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	points := []BehaviorDataPoint{}
	for i := 0; i < 20; i++ {
		points = append(points, BehaviorDataPoint{
			X:         i * 3,
			Y:         i * 2,
			Timestamp: int64(i * 50),
		})
	}

	ratio := service.calculateMicroMovementRatio(points)
	if ratio < 0 || ratio > 1 {
		t.Errorf("Micro movement ratio should be between 0 and 1, got %f", ratio)
	}
}

func TestDetectScrollPattern(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	verticalScrolling := []BehaviorDataPoint{}
	for i := 0; i < 20; i++ {
		verticalScrolling = append(verticalScrolling, BehaviorDataPoint{
			X:         100,
			Y:         i * 20,
			Timestamp: int64(i * 50),
		})
	}
	pattern := service.detectScrollPattern(verticalScrolling)
	if pattern != "vertical_scroll" {
		t.Errorf("Expected vertical_scroll, got %s", pattern)
	}

	horizontalScrolling := []BehaviorDataPoint{}
	for i := 0; i < 20; i++ {
		horizontalScrolling = append(horizontalScrolling, BehaviorDataPoint{
			X:         i * 20,
			Y:         100,
			Timestamp: int64(i * 50),
		})
	}
	pattern = service.detectScrollPattern(horizontalScrolling)
	if pattern != "horizontal_scroll" {
		t.Errorf("Expected horizontal_scroll, got %s", pattern)
	}
}

func TestIsMousePatternHumanLike(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	humanLike := MouseBiometricFeatures{
		MovementEntropy:     3.5,
		BezierCurveFitting: 0.65,
		TrajectoryComplexity: 0.6,
		MicroMovementRatio:  0.15,
		IsHumanLike:        true,
	}

	if !service.isMousePatternHumanLike(humanLike) {
		t.Error("Human-like features should be recognized")
	}

	botLike := MouseBiometricFeatures{
		MovementEntropy:      1.0,
		BezierCurveFitting:   0.98,
		TrajectoryComplexity: 0.05,
		MicroMovementRatio:   0.01,
	}

	if service.isMousePatternHumanLike(botLike) {
		t.Error("Bot-like features should not be recognized as human")
	}
}

func TestAnalyzeKeyboardBiometrics(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	keyStrokes := []KeyboardDataPoint{
		{Key: "a", Timestamp: 0, KeyDownTime: 0, KeyUpTime: 80, HoldDuration: 80},
		{Key: "b", Timestamp: 150, KeyDownTime: 150, KeyUpTime: 230, HoldDuration: 80},
		{Key: "c", Timestamp: 280, KeyDownTime: 280, KeyUpTime: 360, HoldDuration: 80},
		{Key: "d", Timestamp: 450, KeyDownTime: 450, KeyUpTime: 530, HoldDuration: 80},
	}

	features := service.analyzeKeyboardBiometrics(keyStrokes)

	if features.TypingRhythm.MeanInterval < 0 {
		t.Error("Mean interval should be non-negative")
	}

	if features.TypingRhythm.ConsistencyScore < 0 || features.TypingRhythm.ConsistencyScore > 1 {
		t.Error("Consistency score should be between 0 and 1")
	}
}

func TestCalculateDigraphLatency(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	keyStrokes := []KeyboardDataPoint{
		{Key: "a", Timestamp: 0},
		{Key: "b", Timestamp: 150},
		{Key: "c", Timestamp: 300},
		{Key: "a", Timestamp: 450},
		{Key: "b", Timestamp: 600},
	}

	latency := make(map[string]float64)
	service.calculateDigraphLatency(keyStrokes, latency)

	if len(latency) == 0 {
		t.Error("Digraph latency should be calculated")
	}

	expectedKey := "a:b"
	if _, ok := latency[expectedKey]; !ok {
		t.Errorf("Expected digraph %s to be present", expectedKey)
	}
}

func TestAnalyzeTypingRhythm(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	keyStrokes := []KeyboardDataPoint{
		{Key: "t", Timestamp: 0},
		{Key: "e", Timestamp: 180},
		{Key: "s", Timestamp: 350},
		{Key: "t", Timestamp: 520},
	}

	rhythm := service.analyzeTypingRhythm(keyStrokes)

	if rhythm.MeanInterval < 0 {
		t.Error("Mean interval should be non-negative")
	}

	if rhythm.PatternType == "" {
		t.Error("Pattern type should be set")
	}
}

func TestDetectErrorRecoveryPattern(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	keyStrokesNoErrors := []KeyboardDataPoint{
		{Key: "h", Timestamp: 0},
		{Key: "e", Timestamp: 150},
		{Key: "l", Timestamp: 300},
		{Key: "l", Timestamp: 450},
		{Key: "o", Timestamp: 600},
	}
	pattern := service.detectErrorRecoveryPattern(keyStrokesNoErrors)
	if pattern != "no_errors" {
		t.Errorf("Expected no_errors, got %s", pattern)
	}

	keyStrokesWithErrors := []KeyboardDataPoint{
		{Key: "h", Timestamp: 0},
		{Key: "e", Timestamp: 150},
		{Key: "Backspace", Timestamp: 300},
		{Key: "e", Timestamp: 400},
		{Key: "l", Timestamp: 550},
	}
	pattern = service.detectErrorRecoveryPattern(keyStrokesWithErrors)
	if pattern == "no_errors" {
		t.Errorf("Expected some error pattern, got %s", pattern)
	}
}

func TestCalculateFingerLoadBalance(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	keyStrokes := []KeyboardDataPoint{
		{Key: "a", Timestamp: 0},
		{Key: "s", Timestamp: 150},
		{Key: "d", Timestamp: 300},
		{Key: "f", Timestamp: 450},
		{Key: "j", Timestamp: 600},
		{Key: "k", Timestamp: 750},
	}

	balance := make(map[string]float64)
	service.calculateFingerLoadBalance(keyStrokes, balance)

	if balance["left_hand"]+balance["right_hand"] != 1.0 {
		t.Error("Finger load balance should sum to 1")
	}
}

func TestIsKeyboardPatternHumanLike(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	humanKeyboard := KeyboardBiometricFeatures{
		TypingRhythm: TypingRhythm{
			MeanInterval:     150,
			StdDevInterval:  80,
			ConsistencyScore: 0.6,
		},
		FingerLoadBalance: map[string]float64{
			"left_hand":  0.5,
			"right_hand": 0.5,
		},
		DigraphLatency: map[string]float64{
			"t:h": 150,
			"e:r": 120,
			"r:e": 130,
			"s:t": 140,
		},
	}

	if !service.isKeyboardPatternHumanLike(humanKeyboard) {
		t.Error("Human-like keyboard pattern should be recognized")
	}
}

func TestAnalyzeTouchBiometrics(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	events := []TouchEvent{}
	baseTime := time.Now().UnixMilli()

	for i := 0; i < 30; i++ {
		events = append(events, TouchEvent{
			X:         200 + float64(i*5),
			Y:         300 + float64(i*3),
			Timestamp: baseTime + int64(i*30),
			EventType: "swipe",
			Pressure:  0.5,
		})
	}

	features := service.analyzeTouchBiometrics(events)

	if features.SwipeVelocity < 0 {
		t.Error("Swipe velocity should be non-negative")
	}

	if features.PinchGestureRatio < 0 || features.PinchGestureRatio > 1 {
		t.Error("Pinch gesture ratio should be between 0 and 1")
	}
}

func TestCalculateSwipeVelocity(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	events := []TouchEvent{
		{X: 0, Y: 0, Timestamp: 0, EventType: "swipe"},
		{X: 100, Y: 100, Timestamp: 100, EventType: "swipe"},
	}

	velocity := service.calculateSwipeVelocity(events)
	if velocity <= 0 {
		t.Error("Swipe velocity should be positive for moving events")
	}
}

