}

func TestEvaluateBezier(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	controlPoints := []EnhancedPoint{
		{X: 0, Y: 0},
		{X: 10, Y: 10},
		{X: 20, Y: 20},
		{X: 30, Y: 30},
	}

	point := service.evaluateBezier(controlPoints, 0.5)

	if point.X == 0 && point.Y == 0 {
		t.Error("Point at t=0.5 should not be at origin")
	}
}

