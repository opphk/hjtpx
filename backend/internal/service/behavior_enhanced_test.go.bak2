	if len(report) < 100 {
		t.Error("Report should contain substantial content")
	}
}

func TestConcurrency(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	var wg sync.WaitGroup
	for i := 0; i < 10; i++ {
		wg.Add(1)
		go func(idx int) {
			defer wg.Done()

			userID := fmt.Sprintf("user%d", idx%3)
			profile := &DeviceBehaviorPattern{
				DeviceFingerprint: fmt.Sprintf("fp%d", idx),
			}

			service.UpdateDeviceProfile(userID, profile)

		 retrieved := service.GetDeviceProfile(userID)
		 if retrieved == nil {
			 t.Errorf("Profile should be retrievable for user %s", userID)
		 }
		}(i)
	}

	wg.Wait()
}

func TestMeanFloat(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	values := []float64{1, 2, 3, 4, 5}
	mean := service.meanFloat(values)

	if math.Abs(mean-3.0) > 0.001 {
		t.Errorf("Mean should be 3.0, got %f", mean)
	}

	emptyMean := service.meanFloat([]float64{})
	if emptyMean != 0 {
		t.Error("Mean of empty slice should be 0")
	}
}

func TestStdDevFloat(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	values := []float64{2, 4, 4, 4, 5, 5, 7, 9}
	stdDev := service.stdDevFloat(values)

	if stdDev <= 0 {
		t.Error("StdDev should be positive for non-uniform data")
	}

	uniformStdDev := service.stdDevFloat([]float64{5, 5, 5, 5})
	if uniformStdDev != 0 {
		t.Error("StdDev of uniform data should be 0")
	}
}

func TestMedianFloat(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	values := []float64{5, 2, 8, 1, 9, 3, 7, 4, 6}
	median := service.medianFloat(values)

	if median != 5 {
		t.Errorf("Median should be 5, got %f", median)
	}

	evenValues := []float64{1, 2, 3, 4}
	evenMedian := service.medianFloat(evenValues)

	if evenMedian != 2.5 {
		t.Errorf("Median of even count should be 2.5, got %f", evenMedian)
	}
}

func TestPointDistance(t *testing.T) {
	_ = BehaviorDataPoint{X: 0, Y: 0}
	_ = BehaviorDataPoint{X: 3, Y: 4}

	distance := math.Sqrt(3*3 + 4*4)
	expectedDist := distance

	if math.Abs(expectedDist-5.0) > 0.001 {
		t.Errorf("Distance should be 5.0, got %f", expectedDist)
	}
}

