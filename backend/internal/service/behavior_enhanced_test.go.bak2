func TestGetRequestType(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	req1 := map[string]interface{}{"type": "GET"}
	req2 := map[string]interface{}{"method": "POST"}
	req3 := "DELETE"

	reqType1 := service.getRequestType(req1)
	reqType2 := service.getRequestType(req2)
	reqType3 := service.getRequestType(req3)

	if reqType1 != "GET" {
		t.Errorf("Expected GET, got %s", reqType1)
	}
	if reqType2 != "POST" {
		t.Errorf("Expected POST, got %s", reqType2)
	}
	if reqType3 != "DELETE" {
		t.Errorf("Expected DELETE, got %s", reqType3)
	}
}

func TestExtractTimestamp(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	req := map[string]interface{}{"timestamp": float64(1234567890)}

