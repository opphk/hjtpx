func TestCheckIdenticalIntervals(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	behaviorData := []models.BehaviorData{}
	baseTime := time.Now()

	for i := 0; i < 10; i++ {
		point := BehaviorDataPoint{
			X:         i * 10,
			Y:         i * 10,
			Timestamp: baseTime.Add(time.Duration(i*100) * time.Millisecond).UnixMilli(),
			Event:     "move",
		}
		dataBytes, _ := json.Marshal(point)
		behaviorData = append(behaviorData, models.BehaviorData{
			DataType:  "move",
			Data:      string(dataBytes),
			Timestamp: baseTime.Add(time.Duration(i*100) * time.Millisecond),
		})
	}

	identical := service.checkIdenticalIntervals(behaviorData)

	if identical {
		t.Log("Identical intervals detected as expected")
	}
}

