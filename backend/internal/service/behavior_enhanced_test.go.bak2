}

func TestCalculateBiometricScore(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	feature := BiometricFeature{
		MouseMovement: MouseBiometricFeatures{
			IsHumanLike: true,
		},
		KeyboardInput: KeyboardBiometricFeatures{
			IsHumanLike: true,
		},
		TouchBehavior: TouchBiometricFeatures{
			IsHumanLike: true,
		},
	}

	score := service.calculateBiometricScore(feature)
	if score <= 0.5 {
		t.Errorf("Human-like biometric score should be high, got %f", score)
	}
}

func TestCalculateBiometricConfidence(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	feature := BiometricFeature{
		MouseMovement: MouseBiometricFeatures{
			MovementEntropy: 3.5,
		},
		KeyboardInput: KeyboardBiometricFeatures{
			DigraphLatency: map[string]float64{"a:b": 100},
		},
		TouchBehavior: TouchBiometricFeatures{
			SwipeVelocity: 1.5,
		},
	}

	confidence := service.calculateBiometricConfidence(feature)
	if confidence < 0.5 {
		t.Errorf("Confidence should be high with multiple data sources, got %f", confidence)
	}
}

func TestAnalyzeDeviceBehavior(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	behaviorData := []models.BehaviorData{}
	baseTime := time.Now()

	for i := 0; i < 20; i++ {
		point := BehaviorDataPoint{
			X:         100 + i*10,
			Y:         200,
			Timestamp: baseTime.Add(time.Duration(i*100) * time.Millisecond).UnixMilli(),
			Event:     "move",
		}
		dataBytes, _ := json.Marshal(point)
		behaviorData = append(behaviorData, models.BehaviorData{
			DataType:   "move",
			Data:       string(dataBytes),
			Timestamp:  baseTime.Add(time.Duration(i*100) * time.Millisecond),
		})
	}

	deviceData := map[string]interface{}{
		"user_agent": "Mozilla/5.0 Test Browser",
		"fingerprint": "abc123",
		"screen":     "1920x1080",
	}

	pattern := service.analyzeDeviceBehavior(behaviorData, deviceData)

	if pattern.DeviceFingerprint == "" {
		t.Error("Device fingerprint should be generated")
	}

	if len(pattern.SessionPatterns) == 0 {
		t.Error("Session patterns should be extracted")
	}
}

func TestExtractDeviceFingerprint(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	deviceData := map[string]interface{}{
		"user_agent": "Mozilla/5.0",
		"fingerprint": "fp123",
		"screen": "1920x1080",
		"不对": "data",
	}

	fingerprint := service.extractDeviceFingerprint(deviceData)

	if fingerprint == "" {
		t.Error("Fingerprint should not be empty")
	}

	if len(fingerprint) != 64 {
		t.Errorf("SHA256 hash should be 64 characters, got %d", len(fingerprint))
	}
}

func TestExtractSessions(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	baseTime := time.Now()
	behaviorData := []models.BehaviorData{
		{DataType: "move", Timestamp: baseTime},
		{DataType: "click", Timestamp: baseTime.Add(100 * time.Millisecond)},
		{DataType: "move", Timestamp: baseTime.Add(200 * time.Millisecond)},
	}

	sessions := service.extractSessions(behaviorData)

	if len(sessions) < 1 {
		t.Error("At least one session should be extracted")
	}
}

func TestAnalyzeUsageHabits(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	sessions := []SessionPattern{
		{
			SessionID:      "session1",
			StartTime:      time.Date(2024, 1, 15, 10, 0, 0, 0, time.UTC),
			Duration:       60000,
			ActionSequence: []string{"move", "click"},
		},
		{
			SessionID:      "session2",
			StartTime:      time.Date(2024, 1, 15, 14, 0, 0, 0, time.UTC),
			Duration:       90000,
			ActionSequence: []string{"move", "click", "scroll"},
		},
	}

	habits := service.analyzeUsageHabits(sessions)

	if habits.AverageSessionLength <= 0 {
		t.Error("Average session length should be calculated")
	}

	if habits.HabitConsistency < 0 || habits.HabitConsistency > 1 {
		t.Error("Habit consistency should be between 0 and 1")
	}
}

func TestAnalyzeSequencePatterns(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	behaviorData := []models.BehaviorData{
		{DataType: "move", Timestamp: time.Now()},
		{DataType: "click", Timestamp: time.Now().Add(50 * time.Millisecond)},
		{DataType: "move", Timestamp: time.Now().Add(100 * time.Millisecond)},
		{DataType: "click", Timestamp: time.Now().Add(150 * time.Millisecond)},
		{DataType: "scroll", Timestamp: time.Now().Add(200 * time.Millisecond)},
	}

	patterns := service.analyzeSequencePatterns(behaviorData)

	if patterns.SequenceEntropy < 0 {
		t.Error("Sequence entropy should be non-negative")
	}
}

func TestDetectAnomalies(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	behaviorData := []models.BehaviorData{}
	baseTime := time.Now()

	for i := 0; i < 50; i++ {
		point := BehaviorDataPoint{
			X:         100 + i*10,
			Y:         200,
			Timestamp: baseTime.Add(time.Duration(i*20) * time.Millisecond).UnixMilli(),
			Event:     "move",
		}
		dataBytes, _ := json.Marshal(point)
		behaviorData = append(behaviorData, models.BehaviorData{
			DataType:  "move",
			Data:      string(dataBytes),
			Timestamp: baseTime.Add(time.Duration(i*20) * time.Millisecond),
		})
	}

	pattern := DeviceBehaviorPattern{
		SequencePatternMatch: SequencePatternMatch{
			MatchedPatterns:   []string{},
			UnusualSequences: []string{"move->move->move"},
		},
	}

	anomaly := service.detectAnomalies(behaviorData, pattern)

	if anomaly.AnomalyScore < 0 || anomaly.AnomalyScore > 100 {
		t.Error("Anomaly score should be between 0 and 100")
	}
}

func TestCheckDeviceConsistency(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	consistentPattern := DeviceBehaviorPattern{
		SessionPatterns: []SessionPattern{
			{Duration: 60000},
			{Duration: 65000},
			{Duration: 55000},
		},
	}

	if !service.checkDeviceConsistency(consistentPattern) {
		t.Error("Consistent pattern should be recognized")
	}

	inconsistentPattern := DeviceBehaviorPattern{
		SessionPatterns: []SessionPattern{
			{Duration: 1000},
			{Duration: 1000000},
			{Duration: 800},
		},
	}

	if service.checkDeviceConsistency(inconsistentPattern) {
		t.Error("Inconsistent pattern should not be recognized as consistent")
	}
}

