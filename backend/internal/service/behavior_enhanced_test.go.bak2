func TestDetectMultiTouchPattern(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	eventsWithPressure := []TouchEvent{
		{X: 100, Y: 100, Timestamp: 0, EventType: "touch", Pressure: 0.5},
		{X: 200, Y: 200, Timestamp: 100, EventType: "touch", Pressure: 0},
	}

	pattern := service.detectMultiTouchPattern(eventsWithPressure)
	if pattern == "" {
		t.Error("Multi-touch pattern should be detected")
	}
}

func TestCalculatePressureDistribution(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	events := []TouchEvent{
		{X: 100, Y: 100, Timestamp: 0, Pressure: 0.2},
		{X: 200, Y: 200, Timestamp: 100, Pressure: 0.5},
		{X: 300, Y: 300, Timestamp: 200, Pressure: 0.8},
		{X: 400, Y: 400, Timestamp: 300, Pressure: 0},
	}

	distribution := make(map[string]float64)
	service.calculatePressureDistribution(events, distribution)

	total := 0.0
	for _, v := range distribution {
		total += v
	}

	if total < 0.99 || total > 1.01 {
		t.Errorf("Pressure distribution should sum to ~1, got %f", total)
	}
}

