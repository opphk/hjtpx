func TestExportFeatureVector(t *testing.T) {
	service := NewEnhancedBehaviorAnalysisService()

	result := &EnhancedVerificationResult{
		BiometricAnalysis: BiometricFeature{
			OverallScore: 0.7,
			MouseMovement: MouseBiometricFeatures{
				MovementEntropy:     3.5,
				BezierCurveFitting: 0.65,
			},
			KeyboardInput: KeyboardBiometricFeatures{
				TypingRhythm: TypingRhythm{
					MeanInterval:     150,
					StdDevInterval:  80,
					ConsistencyScore: 0.6,
				},
			},
			TouchBehavior: TouchBiometricFeatures{
				SwipeVelocity:      1.5,
				SwipeAngleVariance: 0.8,
			},
		},
		DeviceBehavior: DeviceBehaviorPattern{
			IsConsistent: true,
			AnomalyDetection: AnomalyDetectionResult{
				AnomalyScore: 30,
			},
			SequencePatternMatch: SequencePatternMatch{
				SequenceEntropy: 2.5,
				MatchScore:      0.6,
			},
		},
		NetworkAnalysis: NetworkBehaviorAnalysis{
			BotLikelihoodScore: 40,
			RequestTiming: RequestTimingAnalysis{
				InterRequestInterval: InterRequestInterval{
					MeanInterval: 500,
					StdDevInterval: 100,
					IsTooRegular: false,
				},
			},
			NetworkQuality: NetworkQualityAssessment{
				QualityGrade: "good",
			},
		},
		CrossDeviceTracking: CrossDeviceTracking{
			SuspicionScore: 20,
			BehaviorConsistency: BehaviorConsistency{
				OverallConsistency: 0.8,
			},
			IsSuspiciousSwitch: false,
			AccountLinkage: AccountLinkageResult{
				LinkageStrength: 0.3,
			},
		},
	}

	vector := service.ExportFeatureVector(result)

	if vector["biometric_score"] != 0.7 {
		t.Errorf("Expected biometric_score 0.7, got %f", vector["biometric_score"])
	}

	if len(vector) < 20 {
		t.Error("Feature vector should contain multiple features")
	}
}

