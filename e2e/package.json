{
  "name": "e2e",
  "version": "1.0.0",
  "description": "End-to-end tests for behavior verification system",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:headed": "playwright test --headed",
    "test:report": "npx ts-node utils/report-generator.ts",
    "test:all": "playwright test && npx ts-node utils/report-generator.ts",
    "report": "playwright show-report",
    "install:browsers": "playwright install --with-deps"
  },
  "keywords": ["e2e", "playwright", "testing"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0"
  }
}
